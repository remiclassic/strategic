---
const caseSnapshots = [
	{
		emoji: "🩺",
		title: "Checklist turned paid PDF",
		asset: "12-page clinician intake and boundaries pack",
		price: "$22",
		result: "3 sales in 10 days. First payout under $100 while still seeing clients.",
		color: "#FF4D4D",
	},
	{
		emoji: "👨‍🍳",
		title: "Photos and recipes in one file",
		asset: "Regional recipes PDF using kitchen photos she already had",
		price: "$14",
		result: "11 sales in 18 days from Instagram DMs and one Reddit thread.",
		color: "#4A90E2",
	},
	{
		emoji: "👗",
		title: "Newsletter to wardrobe guide",
		asset: "Capsule wardrobe PDF",
		price: "$17",
		result: "First sale on day 4. 32 sales by week six, about 500 euros before fees.",
		color: "#FFD600",
	},
];
---

<section id="live-proof" class="relative py-24 overflow-hidden bg-gradient-to-br from-[#FFF7E6] via-[#FFFBF2] to-[#FFF7E6]">
	<!-- Background halftone -->
	<div class="absolute inset-0 bg-halftone opacity-5 pointer-events-none mix-blend-multiply"></div>

	<!-- Floating decorative elements -->
	<div class="absolute inset-0 overflow-hidden pointer-events-none">
		<div class="absolute top-10 left-10 text-6xl animate-float">💰</div>
		<div class="absolute bottom-20 right-10 text-6xl animate-float" style="animation-delay: 1s">📊</div>
		<div class="absolute top-1/3 right-1/4 text-5xl animate-float" style="animation-delay: 0.5s">🧾</div>
	</div>

	<div class="container mx-auto px-4 relative z-10">
		<!-- Header -->
		<div class="text-center mb-16 reveal-on-scroll">
			<div class="comic-bubble bg-white inline-block transform -rotate-2 mb-6 hover:rotate-2 transition-all duration-300">
				<p class="text-xl font-bold relative inline-block">
					<span class="relative z-10">⚡ Live Proof</span>
				</p>
			</div>

			<h2 class="text-5xl md:text-6xl mb-8 max-w-4xl mx-auto transform hover:scale-105 transition-all duration-300 font-bold" style="font-family: 'Inter', system-ui, -apple-system, sans-serif;">
				<span class="relative inline-block">
					Same Path as the PDF. Real Numbers.
					<div class="absolute bottom-0 left-0 right-0 h-4 bg-[#FFE066] -rotate-1 -z-10"></div>
				</span>
			</h2>

			<p class="text-lg text-gray-700 max-w-2xl mx-auto leading-relaxed">
				The <span class="font-bold text-[#1B1B3D]">Don't Do Anything</span> guide walks you through: one clear topic, one tight PDF, a simple checkout, then traffic and a 30-day tune-up rhythm. Here is what that looks like when the receipts start showing up.
			</p>
		</div>

		<!-- Main proof grid -->
		<div class="grid grid-cols-1 lg:grid-cols-5 gap-8 mb-16">
			<!-- Dashboard screenshot (takes 3 cols) -->
			<div class="lg:col-span-3 relative group">
				<div class="proof-card bg-white transform hover:scale-[1.02] hover:-rotate-1 transition-all duration-300">
					<!-- Corner badge -->
					<div class="absolute -top-4 -left-4 w-16 h-16 bg-[#FFD600] rounded-full flex items-center justify-center transform -rotate-12 border-4 border-black shadow-xl z-10 group-hover:rotate-12 transition-transform duration-500">
						<span class="text-3xl">🧾</span>
					</div>

					<div class="p-6 md:p-8">
						<div class="flex flex-wrap items-center justify-between gap-3 mb-4">
							<h3 class="text-2xl font-bold" style="font-family: 'Inter', system-ui, -apple-system, sans-serif;">Checkout Dashboard</h3>
							<span class="text-xs font-bold uppercase tracking-wide bg-[#2ECC71] text-white px-3 py-1 rounded-full border-2 border-black">Live</span>
						</div>
						<p class="text-gray-600 text-sm mb-5">
							Sales dashboard cropped for privacy. Real orders, real payouts, no adjectives needed.
						</p>
						<!-- Screenshot with comic frame -->
						<div class="proof-screenshot-frame rounded-xl overflow-hidden">
							<img
								src="/images/proof-dashboard.png"
								alt="Sales dashboard showing $847 total revenue, 142 orders, $215 this month with recent $5 orders"
								class="w-full h-auto"
								loading="lazy"
								decoding="async"
								width="1024"
								height="640"
							/>
						</div>
					</div>
				</div>
			</div>

			<!-- Stat cards (takes 2 cols) -->
			<div class="lg:col-span-2 flex flex-col gap-6">
				<!-- Stat card 1 -->
				<div class="proof-card bg-white transform hover:scale-105 hover:rotate-2 transition-all duration-300 group">
					<div class="p-6 relative overflow-hidden">
						<div class="absolute -top-2 -right-2 text-4xl animate-float" style="animation-delay: 0.2s">⏱️</div>
						<p class="text-xs font-bold uppercase tracking-wide text-gray-500 mb-1">First sale timing</p>
						<p class="text-4xl md:text-5xl font-black text-[#1B1B3D] mb-2" style="font-family: 'Inter', system-ui, sans-serif;">Day 4 to 10</p>
						<p class="text-sm text-gray-600">After a simple launch with honest promotion.</p>
					</div>
				</div>

				<!-- Stat card 2 -->
				<div class="proof-card bg-white transform hover:scale-105 hover:-rotate-2 transition-all duration-300 group">
					<div class="p-6 relative overflow-hidden">
						<div class="absolute -top-2 -right-2 text-4xl animate-float" style="animation-delay: 0.4s">💵</div>
						<p class="text-xs font-bold uppercase tracking-wide text-gray-500 mb-1">Starter price range</p>
						<p class="text-4xl md:text-5xl font-black text-[#1B1B3D] mb-2" style="font-family: 'Inter', system-ui, sans-serif;">$5 to $22</p>
						<p class="text-sm text-gray-600">Most people start with one focused PDF under $25.</p>
					</div>
				</div>

				<!-- Stat card 3 -->
				<div class="proof-card bg-[#1B1B3D] text-white transform hover:scale-105 hover:rotate-2 transition-all duration-300 group">
					<div class="p-6 relative overflow-hidden">
						<div class="absolute -top-2 -right-2 text-4xl animate-float" style="animation-delay: 0.6s">📈</div>
						<p class="text-xs font-bold uppercase tracking-wide text-white/70 mb-1">Early volume</p>
						<p class="text-4xl md:text-5xl font-black text-[#FFE066] mb-2" style="font-family: 'Inter', system-ui, sans-serif;">3 to 11</p>
						<p class="text-sm text-white/80">Sales in the first two to three weeks we hear about.</p>
					</div>
				</div>
			</div>
		</div>

		<!-- Case study cards -->
		<div class="mb-16">
			<div class="text-center mb-10 reveal-on-scroll">
				<h3 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: 'Inter', system-ui, -apple-system, sans-serif;">
					<span class="relative inline-block">
						Same Shape, Different Niches
						<div class="absolute bottom-0 left-0 right-0 h-3 bg-[#FFE066] -rotate-1 -z-10"></div>
					</span>
				</h3>
				<p class="text-gray-600 max-w-xl mx-auto">One topic, one PDF, one price. That mirrors the customer stories further down the page.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{caseSnapshots.map((c, index) => (
					<div class="relative group h-full">
						<div
							class="proof-card bg-white transform hover:scale-105 hover:-rotate-2 transition-all duration-500 h-full flex flex-col"
							style={`animation-delay: ${index * 200}ms`}
						>
							<!-- Emoji badge -->
							<div
								class="absolute -top-4 -left-4 w-14 h-14 rounded-full flex items-center justify-center transform -rotate-12 border-4 border-black shadow-xl z-10 group-hover:rotate-12 transition-transform duration-500"
								style={`background: ${c.color}`}
							>
								<span class="text-2xl">{c.emoji}</span>
							</div>

							<div class="p-6 pt-8 flex flex-col flex-1">
								<p class="text-xs font-bold uppercase tracking-wide text-gray-500 mb-2">{c.title}</p>
								<p class="font-bold text-lg mb-1 leading-snug text-[#1B1B3D]">{c.asset}</p>
								<div class="my-3">
									<span class="inline-block bg-[#FFE066] text-[#1B1B3D] font-black text-2xl px-4 py-1 rounded-lg border-2 border-black transform -rotate-1">{c.price}</span>
								</div>
								<p class="text-gray-700 text-sm leading-relaxed mt-auto border-l-4 border-[#FFD600] pl-3">{c.result}</p>
							</div>

							<!-- Bottom decoration -->
							<div class="absolute bottom-0 left-0 right-0 h-2 bg-black opacity-10 transform group-hover:scale-x-110 transition-transform duration-300"></div>
						</div>
					</div>
				))}
			</div>
		</div>

		<!-- CTA -->
		<div class="text-center reveal-on-scroll">
			<div class="comic-bubble bg-white text-black inline-block transform hover:rotate-3 transition-all duration-300 mb-8">
				<p class="text-xl font-bold flex items-center gap-2">
					Want the exact playbook?
					<span class="inline-block animate-bounce-slow">🦥</span>
				</p>
			</div>
			<br />
			<a
				href="#book-offer"
				class="comic-button bg-black text-white hover:bg-[#2C2D5D] transform hover:scale-105 hover:-rotate-2 transition-all duration-300 inline-flex items-center gap-2 text-xl"
			>
				Get the $5 PDF
				<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 20 20" fill="currentColor">
					<path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
				</svg>
			</a>
		</div>
	</div>
</section>

<style>
	.proof-card {
		border: 4px solid black;
		border-radius: 16px;
		box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.2);
		overflow: hidden;
		position: relative;
	}

	.proof-card:hover {
		box-shadow: 12px 12px 0 rgba(0, 0, 0, 0.15);
	}

	.proof-screenshot-frame {
		border: 3px solid black;
		box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.15);
	}

	.comic-bubble {
		border: 4px solid black;
		border-radius: 12px;
		padding: 1rem 1.5rem;
		box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.2);
	}

	.bg-halftone {
		background-image: radial-gradient(circle at center, black 1px, transparent 1px);
		background-size: 24px 24px;
		background-position: center;
	}

	@keyframes float {
		0%, 100% { transform: translateY(0) rotate(0deg); }
		50% { transform: translateY(-20px) rotate(5deg); }
	}

	.animate-float {
		animation: float 6s ease-in-out infinite;
	}

	@keyframes bounce-slow {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-8px); }
	}

	.animate-bounce-slow {
		animation: bounce-slow 2s ease-in-out infinite;
	}

	.reveal-on-scroll {
		opacity: 0;
		transform: translateY(20px);
		transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.reveal-on-scroll.visible {
		opacity: 1;
		transform: translateY(0);
	}
</style>

<script>
	document.addEventListener('DOMContentLoaded', () => {
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			},
			{ threshold: 0.1, rootMargin: '0px 0px -50px 0px' }
		);

		document.querySelectorAll('#live-proof .reveal-on-scroll').forEach((el) => observer.observe(el));
	});
</script>
