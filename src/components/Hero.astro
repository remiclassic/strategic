---
import { starterGuidePricing, starterGuideDiscountPercent } from '../data/starter-guide-offer';

const starterSavePct = starterGuideDiscountPercent();
---

<section id="hero" class="relative md:min-h-[100dvh] w-full overflow-hidden bg-[#FFD600]">
	<!-- Background Plants and Sloth - Absolute position for contained scroll effect (desktop only) -->
	<div class="absolute inset-0 overflow-hidden pointer-events-none hidden lg:block" id="hero-images-container">
		<img
			src="/images/plants.webp"
			alt="Decorative Plants"
			width="1024"
			height="1024"
			loading="eager"
			fetchpriority="high"
			decoding="async"
			class="absolute bottom-0 -right-[15%] w-[100%] md:w-[90%] h-auto object-contain object-bottom opacity-80 will-change-transform"
			style="max-height: 100vh;"
			id="hero-plant"
		/>
		<img
			src="/images/slothloungehero.webp"
			alt="Strategic Sloth"
			width="954"
			height="1042"
			loading="eager"
			fetchpriority="high"
			decoding="async"
			class="absolute bottom-0 -right-[5%] w-[110%] md:w-[80%] h-auto object-contain object-bottom will-change-transform z-10"
			style="max-height: 95vh;"
			id="hero-sloth"
		/>
	</div>

	<!-- Floating Zzz Background -->
	<div class="absolute inset-0 pointer-events-none overflow-hidden">
		<svg class="floating-z absolute top-[20%] left-[15%] w-12 h-12" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M8 12H32L12 28H32" stroke="#2C2D5D" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
		<svg class="floating-z delay-1 absolute top-[30%] right-[25%] w-14 h-14" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M8 12H32L12 28H32" stroke="#2C2D5D" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
		<svg class="floating-z delay-2 absolute top-[15%] right-[40%] w-10 h-10" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M8 12H32L12 28H32" stroke="#2C2D5D" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
		<svg class="floating-z delay-3 absolute top-[40%] left-[35%] w-12 h-12" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
			<path d="M8 12H32L12 28H32" stroke="#2C2D5D" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
		</svg>
	</div>

	<div class="container-custom relative z-10 mx-auto flex md:min-h-[100dvh] flex-col lg:flex-row items-start lg:items-center justify-between gap-8 px-4 py-16 sm:px-6 lg:px-8">
		<div class="w-full lg:w-[48%] flex flex-col items-center lg:items-start text-center lg:text-left space-y-5">
			<div class="relative bg-[#E3F2FF] rounded-2xl p-3 sm:p-4 border-2 border-black inline-block transform -rotate-6 mt-4 md:mt-12 max-w-[min(100%,20rem)] text-center">
				<span class="font-black text-base leading-tight sm:text-lg sm:leading-snug text-[#1B1B3D]">
					{
						`${starterSavePct}% off · $${starterGuidePricing.currentPrice} starter PDF · was $${starterGuidePricing.regularPrice}`
					}
				</span>
				<div class="absolute -bottom-[8.5px] left-1/2 transform -translate-x-1/2 rotate-45 w-4 h-4 bg-[#E3F2FF]"></div>
				<div class="absolute -bottom-[9.5px] left-1/2 transform -translate-x-1/2 rotate-45 w-4 h-4 border-r-2 border-b-2 border-black"></div>
			</div>

			<h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black text-[#1B1B3D] italic leading-tight" style="font-family: 'Inter', sans-serif;">
				Build Income That<br />Runs Without You
			</h1>

			<p class="flex w-full max-w-xl mx-auto lg:mx-0 max-sm:justify-center lg:justify-start flex-nowrap items-start gap-2.5 sm:gap-2 rounded-full border-2 border-black bg-white/95 px-4 py-2 text-left text-sm sm:text-base font-bold text-[#1B1B3D] shadow-[3px_3px_0_0_rgba(0,0,0,1)]">
				<span class="shrink-0 select-none max-sm:text-3xl max-sm:leading-none leading-snug" aria-hidden="true">🌴</span>
				<span class="min-w-0 max-sm:max-w-[13.5rem] sm:max-w-none sm:flex-1 leading-snug text-pretty">Join 5,000+ creators building calmer, background income</span>
			</p>

			<p class="text-lg md:text-xl text-[#1B1B3D] font-medium max-w-xl mx-auto lg:mx-0 leading-snug">
				Turn what you know into a simple digital product and the small systems around it. After that quiet setup, checkout and delivery can run without you babysitting every sale.
			</p>

			<p class="text-xl md:text-2xl text-[#1B1B3D] font-bold max-w-xl mx-auto lg:mx-0 leading-snug">
				This isn&apos;t just a book.<br />
				<span class="italic font-bold">It&apos;s your first step beyond the 9 to 5.</span>
			</p>

			<div class="flex w-full max-w-md flex-col gap-4 overflow-visible">
				<a
					href="#book-offer"
					class="relative order-1 block w-full max-w-[240px] sm:max-w-[280px] mx-auto lg:mx-0 group transition-transform hover:scale-[1.02]"
				>
					<div class="absolute inset-0 bg-black translate-x-2 translate-y-2 rounded-lg group-hover:translate-x-1 group-hover:translate-y-1 transition-transform"></div>
					<img
						src="/images/bookpdf.webp"
						alt="Don't Do Anything – tap to see the $5 starter guide"
						width="1024"
						height="1536"
						loading="eager"
						decoding="async"
						class="relative w-full h-auto rounded-lg border-2 border-black"
					/>
				</a>

				<div class="order-2 w-full space-y-2.5 overflow-visible">
					<div class="relative isolate">
						<div class="absolute inset-0 z-0 bg-black translate-x-2 translate-y-2 rounded-xl" aria-hidden="true"></div>
						<a
							href="#book-offer"
							class="relative z-[1] block w-full bg-[#2C2D5D] text-white px-3 py-3 sm:px-8 sm:py-6 rounded-xl font-black text-xs leading-snug sm:text-2xl sm:leading-normal border-2 border-black hover:translate-x-1 hover:translate-y-1 transition-transform cta-button text-center"
						>
							<div class="cta-particles" aria-hidden="true"></div>
							✅ SHOW ME HOW TO EARN WHILE I NAP
						</a>
						<img
							src="/images/paw.webp"
							alt=""
							width="859"
							height="623"
							loading="eager"
							decoding="async"
							class="pointer-events-none absolute -left-10 sm:-left-16 -top-6 sm:-top-8 z-20 h-20 w-20 sm:h-24 sm:w-24 object-contain animate-paw-float select-none"
							aria-hidden="true"
						/>
					</div>

					<div
						class="rounded-2xl border-2 border-black bg-[#FFFDF7] p-3 sm:p-5 text-center shadow-[4px_4px_0_0_rgba(0,0,0,0.06)]"
					>
						<div class="grid grid-cols-2 gap-2 sm:gap-4">
							<a
								href="#book-offer"
								title="Grab the $5 PDF and see exactly what is inside"
								class="flex min-h-[2.75rem] items-center justify-center rounded-lg border-2 border-black bg-[#FFD600] px-2 py-2 text-center text-[11px] font-black leading-tight text-[#1B1B3D] transition-colors hover:bg-[#FFE44D] active:bg-[#FFEC80] sm:min-h-[3.5rem] sm:rounded-xl sm:px-4 sm:py-3.5 sm:text-base"
							>
								$5 starter PDF
							</a>
							<a
								href="#get-started"
								title="View pricing and full library packages"
								class="flex min-h-[2.75rem] items-center justify-center rounded-lg border-2 border-black bg-white px-2 py-2 text-center text-[11px] font-black leading-tight text-[#1B1B3D] transition-colors hover:bg-[#E3F2FF] active:bg-[#D7EBFA] sm:min-h-[3.5rem] sm:rounded-xl sm:px-4 sm:py-3.5 sm:text-base"
							>
								Full packages from $17
							</a>
						</div>

						<div
							class="mt-3 grid grid-cols-2 gap-2 border-t-2 border-dashed border-black/15 pt-3 sm:mt-5 sm:gap-3 sm:pt-5"
						>
							<a
								href="#live-proof"
								title="Jump to live checkout proof on this page"
								class="flex min-h-[2.75rem] flex-col items-center justify-center gap-0.5 rounded-lg border-2 border-dashed border-black/45 bg-white/90 px-2 py-2 text-center text-[11px] font-black leading-tight text-[#1B1B3D] shadow-[2px_2px_0_0_rgba(0,0,0,0.06)] transition-all hover:border-solid hover:border-black hover:bg-[#E3F2FF] hover:shadow-[3px_3px_0_0_rgba(0,0,0,0.1)] active:translate-x-px active:translate-y-px active:shadow-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1B1B3D] focus-visible:ring-offset-2 sm:min-h-[3rem] sm:rounded-xl sm:px-3 sm:text-sm"
							>
								<span class="text-sm leading-none sm:text-base" aria-hidden="true">↓</span>
								<span>Real checkout proof</span>
							</a>
							<a
								href="#process-path"
								title="Jump to the 3-step path on this page"
								class="flex min-h-[2.75rem] flex-col items-center justify-center gap-0.5 rounded-lg border-2 border-dashed border-black/45 bg-white/90 px-2 py-2 text-center text-[11px] font-black leading-tight text-[#1B1B3D] shadow-[2px_2px_0_0_rgba(0,0,0,0.06)] transition-all hover:border-solid hover:border-black hover:bg-[#E3F2FF] hover:shadow-[3px_3px_0_0_rgba(0,0,0,0.1)] active:translate-x-px active:translate-y-px active:shadow-none focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#1B1B3D] focus-visible:ring-offset-2 sm:min-h-[3rem] sm:rounded-xl sm:px-3 sm:text-sm"
							>
								<span class="text-sm leading-none sm:text-base" aria-hidden="true">↓</span>
								<span>3-step path</span>
							</a>
						</div>
					</div>
				</div>
			</div>

			<details class="w-full max-w-md text-left rounded-xl border-2 border-black bg-white/80 px-3 py-2.5 sm:px-4 sm:py-3 group">
				<summary class="font-bold text-[#1B1B3D] cursor-pointer list-none flex items-center justify-between gap-2">
					<span>Not “passive overnight”: what to expect</span>
					<span class="text-xl leading-none group-open:rotate-180 transition-transform">▼</span>
				</summary>
				<p class="mt-3 text-sm text-[#1B1B3D]/80 leading-relaxed">
					Real work up front: pick the offer, build the asset, wire checkout, then improve in small passes. Most people need weeks to launch something solid. The sloth still builds the branch before it rests on it.
				</p>
			</details>

			<div class="w-full max-w-md mx-auto lg:mx-0">
				<p class="comic-title text-center lg:text-left text-lg sm:text-xl text-[#1B1B3D] tracking-wide mb-3">
					Step-by-step path
				</p>
				<p class="sr-only">Step-by-step: idea, then asset, then upload, then first sales.</p>
				<div
					class="hero-step-row flex flex-nowrap items-center justify-between gap-0.5 sm:gap-1 overflow-x-visible overflow-y-visible pb-3 -mx-1 px-1 sm:mx-0 sm:px-0 sm:overflow-visible [scrollbar-width:thin]"
					aria-hidden="true"
				>
					<div class="flex flex-col items-center gap-1 w-[3.25rem] sm:w-16 shrink-0">
						<span class="hero-step-seq hero-step-seq--1 select-none text-[1.65rem] leading-none sm:text-4xl" aria-hidden="true">💡</span>
						<span class="hero-step-label hero-step-label--1 text-center text-[10px] sm:text-xs font-black leading-tight text-[#1B1B3D]">Idea</span>
					</div>
					<span class="shrink-0 pb-5 text-base font-black text-[#1B1B3D]/40 sm:pb-6 sm:text-lg">→</span>
					<div class="flex flex-col items-center gap-1 w-[3.25rem] sm:w-16 shrink-0">
						<span class="hero-step-seq hero-step-seq--2 select-none text-[1.65rem] leading-none sm:text-4xl" aria-hidden="true">📄</span>
						<span class="hero-step-label hero-step-label--2 text-center text-[10px] sm:text-xs font-black leading-tight text-[#1B1B3D]">Asset</span>
					</div>
					<span class="shrink-0 pb-5 text-base font-black text-[#1B1B3D]/40 sm:pb-6 sm:text-lg">→</span>
					<div class="flex flex-col items-center gap-1 w-[3.25rem] sm:w-16 shrink-0">
						<span class="hero-step-seq hero-step-seq--3 select-none text-[1.65rem] leading-none sm:text-4xl" aria-hidden="true">📤</span>
						<span class="hero-step-label hero-step-label--3 text-center text-[10px] sm:text-xs font-black leading-tight text-[#1B1B3D]">Upload</span>
					</div>
					<span class="shrink-0 pb-5 text-base font-black text-[#1B1B3D]/40 sm:pb-6 sm:text-lg">→</span>
					<div class="relative z-[2] flex w-[3.75rem] flex-col items-center gap-1 overflow-visible sm:w-[4.25rem]">
						<div class="relative flex min-h-[2.75rem] w-full items-end justify-center overflow-visible sm:min-h-[3.25rem]">
							<span class="hero-step-seq hero-step-seq--4 select-none text-[1.65rem] leading-none sm:text-4xl" aria-hidden="true">💸</span>
							<span class="hero-step-income hero-step-income--a" aria-hidden="true">💲</span>
							<span class="hero-step-income hero-step-income--b" aria-hidden="true">💵</span>
							<span class="hero-step-income hero-step-income--c" aria-hidden="true">💲</span>
							<span class="hero-step-income hero-step-income--d" aria-hidden="true">💵</span>
						</div>
						<span class="hero-step-label hero-step-label--4 text-center text-[10px] sm:text-xs font-black leading-tight text-[#1B1B3D]">First sales</span>
					</div>
				</div>
			</div>

			<p
				class="flex max-w-md flex-wrap items-center justify-center gap-x-2 gap-y-1 rounded-xl border-2 border-black bg-white/90 px-3 py-2 text-center text-xs font-semibold text-[#1B1B3D] sm:justify-start sm:text-sm lg:mx-0"
			>
				<span class="inline-flex items-center gap-1"><span aria-hidden="true">⚡</span>Instant access</span>
				<span class="text-[#1B1B3D]/30" aria-hidden="true">·</span>
				<span class="inline-flex items-center gap-1"><span aria-hidden="true">🔒</span>Secure payment</span>
				<span class="text-[#1B1B3D]/30" aria-hidden="true">·</span>
				<span class="inline-flex items-center gap-1"><span aria-hidden="true">✨</span>30-day guarantee</span>
			</p>

			<div class="max-w-md rounded-xl border-2 border-black bg-white/80 p-3 text-left text-sm italic text-[#1B1B3D] sm:p-4 sm:text-base">
				“Helped me start something outside of my day job. Simple to follow.”
				<span class="mt-1 block font-bold not-italic">– David R.</span>
			</div>
		</div>

		<div class="w-full lg:w-[52%]"></div>
	</div>

	<div class="block lg:hidden relative w-full pointer-events-none">
		<img
			src="/images/plants.webp"
			alt="Decorative Plants"
			width="1024"
			height="1024"
			loading="eager"
			decoding="async"
			class="absolute bottom-0 right-0 w-full h-auto object-contain object-bottom opacity-80"
		/>
		<img
			src="/images/slothloungehero.webp"
			alt="Strategic Sloth"
			width="954"
			height="1042"
			loading="eager"
			decoding="async"
			class="relative w-[85%] max-w-[400px] mx-auto h-auto object-contain"
		/>
	</div>

	<div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce-slow cursor-pointer z-20">
		<div class="flex items-center justify-center">
			<span class="text-2xl">🦥</span>
			<span class="text-white text-xl ml-2">↓</span>
		</div>
		<p class="text-white font-bold text-base">Scroll down</p>
	</div>
</section>

<script>
	{
		const heroSection = document.getElementById('hero');
		const plantImage = document.getElementById('hero-plant');
		const slothImage = document.getElementById('hero-sloth');

		if (heroSection && plantImage && slothImage) {
			let heroTicking = false;

			const updateHeroParallax = () => {
				const rect = heroSection.getBoundingClientRect();
				const sectionH = rect.height;
				const viewportH = window.innerHeight;
				const scrolled = Math.max(0, -rect.top);
				const offset = Math.min(0, scrolled - (sectionH - viewportH));

				plantImage.style.transform = `translateY(${offset}px)`;
				slothImage.style.transform = `translateY(${offset}px)`;
				heroTicking = false;
			};

			window.addEventListener(
				'scroll',
				() => {
					if (!heroTicking) {
						requestAnimationFrame(updateHeroParallax);
						heroTicking = true;
					}
				},
				{ passive: true },
			);
			updateHeroParallax();
		}
	}

	const scrollIndicator = document.querySelector('.animate-bounce-slow');
	if (scrollIndicator) {
		scrollIndicator.addEventListener('click', () => {
			const nextSection = document.querySelector('section:nth-of-type(2)');
			if (nextSection) {
				nextSection.scrollIntoView({ behavior: 'smooth' });
			}
		});
	}
</script>

<style>
	section {
		background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 5C32 5 34 7 34 9C34 11 32 13 30 13C28 13 26 11 26 9C26 7 28 5 30 5ZM22 14C24 14 26 16 26 18C26 20 24 22 22 22C20 22 18 20 18 18C18 16 20 14 22 14ZM38 14C40 14 42 16 42 18C42 20 40 22 38 22C36 22 34 20 34 18C34 16 36 14 38 14ZM30 23C35 23 39 27 39 32C39 37 35 41 30 41C25 41 21 37 21 32C21 27 25 23 30 23Z' fill='%23FFB800' fill-opacity='0.1'/%3E%3C/svg%3E");
	}

	details > summary::-webkit-details-marker {
		display: none;
	}

	.cta-button {
		position: relative;
		overflow: hidden;
		text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.2);
	}

	.cta-button:hover {
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
	}

	.cta-button::before {
		content: '';
		position: absolute;
		top: -50%;
		left: -50%;
		width: 200%;
		height: 200%;
		background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);
		transform: rotate(45deg);
		animation: shine 3s infinite;
	}

	.cta-particles {
		position: absolute;
		inset: 0;
		pointer-events: none;
	}

	.cta-button:hover .cta-particles::before,
	.cta-button:hover .cta-particles::after {
		content: '✨';
		position: absolute;
		animation: particle 1s ease-in-out infinite;
	}

	.cta-button:hover .cta-particles::before {
		left: 10%;
		animation-delay: 0.2s;
	}

	.cta-button:hover .cta-particles::after {
		right: 10%;
		animation-delay: 0.4s;
	}

	@keyframes shine {
		0% {
			transform: translateX(-100%) rotate(45deg);
		}
		100% {
			transform: translateX(100%) rotate(45deg);
		}
	}

	@keyframes particle {
		0% {
			transform: translateY(0) scale(1);
			opacity: 1;
		}
		100% {
			transform: translateY(-20px) scale(0.5);
			opacity: 0;
		}
	}

	@keyframes paw-tap {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg);
		}
		15% {
			transform: translate(0, 0) rotate(0deg);
		}
		20% {
			transform: translate(0, 8px) rotate(5deg);
		}
		25% {
			transform: translate(0, 0) rotate(0deg);
		}
		30% {
			transform: translate(0, 0) rotate(0deg);
		}
		35% {
			transform: translate(0, 8px) rotate(5deg);
		}
		40% {
			transform: translate(0, 0) rotate(0deg);
		}
		60% {
			transform: translate(0, 0) rotate(0deg);
		}
		65% {
			transform: translate(0, 8px) rotate(5deg);
		}
		70% {
			transform: translate(0, 0) rotate(0deg);
		}
		75% {
			transform: translate(0, 0) rotate(0deg);
		}
		80% {
			transform: translate(0, 8px) rotate(5deg);
		}
		85% {
			transform: translate(0, 0) rotate(0deg);
		}
	}

	.animate-paw-float {
		animation: paw-tap 4s ease-in-out infinite;
	}

	.floating-z {
		animation: floatZ 8s ease-in-out infinite;
		opacity: 0.1;
	}

	.delay-1 {
		animation-delay: 2s;
	}

	.delay-2 {
		animation-delay: 4s;
	}

	.delay-3 {
		animation-delay: 6s;
	}

	@keyframes floatZ {
		0%,
		100% {
			transform: translate(0, 0) rotate(0deg);
			opacity: 0.05;
		}
		50% {
			transform: translate(0, -30px) rotate(5deg);
			opacity: 0.1;
		}
	}

	@keyframes bounce-slow {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-6px);
		}
	}

	.animate-bounce-slow {
		animation: bounce-slow 2s infinite;
	}

	/* Step path: no boxes — sequential spotlight (8s loop) + income burst on beat 4 */
	#hero .hero-step-seq {
		display: inline-block;
		transform-origin: center bottom;
		animation-duration: 8s;
		animation-timing-function: ease-in-out;
		animation-iteration-count: infinite;
	}

	#hero .hero-step-seq--1 {
		animation-name: hero-step-spot-1;
	}
	#hero .hero-step-seq--2 {
		animation-name: hero-step-spot-2;
	}
	#hero .hero-step-seq--3 {
		animation-name: hero-step-spot-3;
