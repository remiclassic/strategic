---
interface Props {
  text?: string;
}
const { text = 'Or explore individual guides' } = Astro.props;
---

<div class="section-divider">
  <div class="section-divider__line"></div>
  <span class="section-divider__text">{text}</span>
  <div class="section-divider__line"></div>
</div>

<style>
  .section-divider {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 2.5rem 1.25rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .section-divider__line {
    flex: 1;
    height: 1.5px;
    background: #d0d0e4;
  }

  .section-divider__text {
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    font-weight: 600;
    color: #8888aa;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }
</style>
