---
const bullets = [
  { emoji: "🗂️", text: "Turn ideas into structured products, without the chaos of figuring out the format yourself." },
  { emoji: "🧘", text: "Organize your content without overwhelm, one step at a time, in a system built for actual humans." },
  { emoji: "🚀", text: "Build and launch faster, because the hard parts are already handled for you." },
];
---

<section id="narriaflow" class="relative overflow-hidden border-t-[3px] border-black bg-[#1B1B3D] py-20">
  <div class="narria-deco pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <span class="narria-float narria-float--1">🚀</span>
    <span class="narria-float narria-float--2">✨</span>
    <span class="narria-float narria-float--3">🦥</span>
  </div>
  <div class="container-custom relative z-10 mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">

      <!-- Eyebrow -->
      <div class="mb-6 flex items-center gap-3">
        <div class="inline-flex items-center gap-2 rounded-full border-2 border-black bg-[#FFD600] px-4 py-1.5 shadow-[3px_3px_0_#000]">
          <span class="text-sm">✦</span>
          <span class="text-xs font-black uppercase tracking-widest text-black" style="font-family:'Inter',system-ui,sans-serif;">Coming Next</span>
        </div>
      </div>

      <!-- Heading -->
      <h2 class="mb-6 text-[clamp(2rem,5vw,3.25rem)] font-black leading-tight text-white drop-shadow-[2px_2px_0_rgba(0,0,0,0.35)]" style="font-family: Bangers, cursive; letter-spacing: 0.03em;">
        These Tools Are<br class="hidden sm:block" /> Just the Start
      </h2>

      <!-- Body -->
      <p class="text-[#B8B8D4] text-lg leading-relaxed mb-10 max-w-2xl" style="font-family:'Inter',system-ui,sans-serif;">
        NarriaFlow is being built to help creators, freelancers, and everyday smart people turn their ideas into digital products, without getting buried in tech, design, or busywork.
      </p>

      <!-- Bullets -->
      <div class="mb-12 grid gap-5 sm:grid-cols-3">
        {bullets.map((b) => (
          <div class="narria-bullet group flex flex-col gap-3 rounded-2xl border-2 border-white/15 bg-white/5 p-5 transition-all duration-200 hover:border-[#FFD600]/40 hover:bg-white/10">
            <span class="narria-bullet-emoji text-3xl transition-transform duration-200 group-hover:scale-110">{b.emoji}</span>
            <p class="text-sm font-medium leading-relaxed text-white" style="font-family:'Inter',system-ui,sans-serif;">{b.text}</p>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <button
          type="button"
          class="waitlist-trigger inline-flex items-center gap-2 bg-[#FFD600] text-black font-black text-base px-8 py-4 rounded-xl border-[3px] border-[#FFD600] shadow-[4px_4px_0_rgba(255,214,0,0.3)] hover:shadow-[2px_2px_0_rgba(255,214,0,0.3)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-150"
          data-tool-name="NarriaFlow Early Access"
          data-tool-desc="Be first to access NarriaFlow when it launches, the full platform for turning ideas into digital products."
          style="font-family:'Inter',system-ui,sans-serif;"
        >
          ✉️ Get Early Access to NarriaFlow
        </button>
        <p class="text-[#8888A4] text-sm" style="font-family:'Inter',system-ui,sans-serif;">
          Start with one simple idea now. Build the full system later.
        </p>
      </div>

    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('#narriaflow .waitlist-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const name = (btn as HTMLElement).dataset.toolName ?? '';
        const desc = (btn as HTMLElement).dataset.toolDesc ?? '';
        if (typeof (window as any).openWaitlistModal === 'function') {
          (window as any).openWaitlistModal(name, desc);
        }
      });
    });
  });
</script>

<style>
  .narria-float {
    position: absolute;
    font-size: clamp(2.25rem, 6vw, 3.5rem);
    line-height: 1;
    opacity: 0.12;
    animation: narriaDrift 10s ease-in-out infinite;
  }
  .narria-float--1 {
    top: 8%;
    right: 8%;
  }
  .narria-float--2 {
    bottom: 22%;
    left: 6%;
    animation-delay: 2s;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
  }
  .narria-float--3 {
    top: 42%;
    left: 4%;
    animation-delay: 4.5s;
    opacity: 0.1;
  }
  @keyframes narriaDrift {
    0%,
    100% {
      transform: translate(0, 0) rotate(-6deg);
    }
    50% {
      transform: translate(-8px, -14px) rotate(6deg);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .narria-float {
      animation: none;
    }
    .narria-bullet-emoji {
      transition: none;
    }
    .narria-bullet.group:hover .narria-bullet-emoji {
      transform: none;
    }
  }
</style>
