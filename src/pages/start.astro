<script>
	{
		const hero = document.getElementById('start-hero');
		const sticky = document.querySelector('.start-sticky-cta');
		if (hero && sticky) {
			let lastY = window.scrollY;
			const tick = () => {
				const pastHero = hero.getBoundingClientRect().bottom < 56;
				const y = window.scrollY;
				const dy = y - lastY;
				lastY = y;
				if (!pastHero) {
					sticky.classList.add('start-sticky-cta--hidden');
					return;
				}
				if (dy < -8) sticky.classList.add('start-sticky-cta--hidden');
				else sticky.classList.remove('start-sticky-cta--hidden');
			};
			tick();
			window.addEventListener('scroll', () => requestAnimationFrame(tick), { passive: true });
		}
	}
</script>

