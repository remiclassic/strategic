---
import Layout from '../layouts/Layout.astro';
import ExitIntentPopup from '../components/ExitIntentPopup.astro';

/** Same Lemon Squeezy checkouts as `Pricing.astro` (index). */
const CHECKOUT_STARTER =
	'https://strategicsloth.lemonsqueezy.com/checkout/buy/fd467bf3-1dd0-4e1c-92a5-d0dfcbd8646a?embed=1';
const CHECKOUT_BEST_VALUE =
	'https://strategicsloth.lemonsqueezy.com/checkout/buy/79792bc4-e1aa-47a8-948b-1058c47d0288?embed=1';
const CHECKOUT_SCALE =
	'https://strategicsloth.lemonsqueezy.com/checkout/buy/64915b54-7f09-4184-add3-1f87b83a5cd0?embed=1';
---

<Layout title="Your Library – What's Inside | Strategic Sloth" description="Every Strategic Sloth book in three tiers, from escaping the 9-to-5 grind to a more sovereign, location-independent setup. Real reading and implementation time, not an overnight flip.">

<!-- Hero -->
<section class="rl-hero relative overflow-hidden border-b-[3px] border-black py-20 md:py-28 bg-[#FFD600]">
	<div class="rl-hero-pattern absolute inset-0 pointer-events-none" aria-hidden="true"></div>
	<div class="rl-float-layer absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
		<span class="rl-float rl-float--1">📚</span>
		<span class="rl-float rl-float--2">🗺️</span>
		<span class="rl-float rl-float--3">🦥</span>
		<span class="rl-float rl-float--4">🏦</span>
		<span class="rl-float rl-float--5">✨</span>
		<span class="rl-float rl-float--6">🛂</span>
		<span class="rl-float rl-float--7">🔐</span>
	</div>
	<div class="rl-z-layer absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
		<svg class="rl-z rl-z--1" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 12H32L12 28H32" stroke="#2C2D5D" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>
		<svg class="rl-z rl-z--2" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 12H32L12 28H32" stroke="#2C2D5D" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>
		<svg class="rl-z rl-z--3" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8 12H32L12 28H32" stroke="#2C2D5D" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/></svg>
	</div>

	<div class="container mx-auto px-4 relative z-10 text-center max-w-3xl">
		<div class="flex justify-center mb-6">
			<span class="rl-hero-badge inline-flex items-center gap-2 bg-white border-[3px] border-black rounded-full px-5 py-2 shadow-[4px_4px_0_#000] text-[#1B1B3D] font-extrabold text-sm tracking-wide uppercase">
				📖 Freedom Library
			</span>
		</div>

		<h1 class="rl-hero-title text-[clamp(2.5rem,7vw,4.25rem)] leading-[1.05] mb-5 text-[#1B1B3D]" style="font-family:'Bangers',cursive;letter-spacing:0.02em;">
			11 Books · 3 Tiers<br />
			<span class="rl-hero-title-accent italic">One Complete System</span>
		</h1>

		<p class="text-lg md:text-xl text-[#2a2a4a] font-medium mb-6 max-w-2xl mx-auto leading-relaxed">
			Every book solves a specific problem. Together they help you move from <strong class="text-[#1B1B3D]">stuck in the grind</strong> toward <strong class="text-[#1B1B3D]">sovereign, location-independent, and protected</strong> with steady effort, the slow way.
		</p>

		<div class="flex flex-wrap justify-center gap-2 mb-8">
			<span class="rl-stat-pill"><span class="rl-stat-emoji">🌱</span> Tier 1 · Foundation</span>
			<span class="rl-stat-pill"><span class="rl-stat-emoji">🏗️</span> Tier 2 · Structure</span>
			<span class="rl-stat-pill"><span class="rl-stat-emoji">🚀</span> Tier 3 · Scale</span>
		</div>

		<div class="flex flex-col sm:flex-row gap-3 justify-center items-center mb-6">
			<a href="#starter" class="rl-cta-primary">Jump to Starter →</a>
			<a href="#builder" class="rl-cta-secondary">Peek at Builder</a>
		</div>

		<p class="text-base text-[#1B1B3D]/75 italic font-medium">
			Each tier builds on the last. Read in order. No skipping ahead.
		</p>
		<p class="text-sm text-[#1B1B3D]/55 mt-5 max-w-xl mx-auto leading-relaxed">
			Sovereignty guides: banking, tax, residency &amp; citizenship.
			<a href="/books" class="font-bold text-[#1B1B3D] underline underline-offset-2 hover:opacity-80 transition-opacity">Creator Guides (digital products) →</a>
		</p>
	</div>
</section>

<!-- Quick Comparison -->
<section id="packages" class="rl-compare relative py-16 border-b-[3px] border-black overflow-hidden">
	<div class="rl-compare-blob rl-compare-blob--tr" aria-hidden="true"></div>
	<div class="rl-compare-blob rl-compare-blob--bl" aria-hidden="true"></div>
	<div class="container mx-auto px-4 max-w-5xl relative z-10">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			<!-- Starter -->
			<a href={CHECKOUT_STARTER} class="lemonsqueezy-button compare-card group relative bg-amber-50 border-4 border-black rounded-2xl p-6 text-center shadow-[4px_4px_0_rgba(0,0,0,0.15)] hover:shadow-[6px_6px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300 no-underline">
				<img src="/images/starterpackage.webp" alt="Starter Package Sloth" width="128" height="128" loading="eager" decoding="async" class="w-20 h-20 object-contain mx-auto mb-3 group-hover:scale-110 transition-transform duration-300" />
				<div class="inline-block bg-[#FFE066] border-2 border-black rounded-full px-4 py-1 text-xs font-black tracking-wide mb-3">STARTER</div>
				<h3 class="text-lg font-black text-[#1B1B3D] mb-1" style="font-family:'Inter',system-ui,sans-serif;">2 Books</h3>
				<p class="text-sm text-gray-600 mb-3">Income + Life Design</p>
				<span class="text-2xl font-black text-[#1B1B3D]">$17</span>
			</a>

			<!-- Builder -->
			<a href={CHECKOUT_BEST_VALUE} class="lemonsqueezy-button compare-card group relative bg-blue-50 border-4 border-black rounded-2xl p-6 text-center shadow-[4px_4px_0_rgba(0,0,0,0.15)] hover:shadow-[6px_6px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300 no-underline">
				<div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-[#4D9FFF] text-white text-xs font-black px-4 py-1 rounded-full border-2 border-black">MOST POPULAR</div>
				<img src="/images/bestvalue.webp" alt="Best Value Package Sloth" width="128" height="128" loading="eager" decoding="async" class="w-20 h-20 object-contain mx-auto mb-3 group-hover:scale-110 transition-transform duration-300" />
				<div class="inline-block bg-[#4D9FFF] text-white border-2 border-black rounded-full px-4 py-1 text-xs font-black tracking-wide mb-3">BUILDER</div>
				<h3 class="text-lg font-black text-[#1B1B3D] mb-1" style="font-family:'Inter',system-ui,sans-serif;">6 Books</h3>
				<p class="text-sm text-gray-600 mb-3">Income + Sovereignty</p>
				<span class="text-2xl font-black text-[#1B1B3D]">$47</span>
			</a>

			<!-- Scale -->
			<a href={CHECKOUT_SCALE} class="lemonsqueezy-button compare-card group relative bg-red-50 border-4 border-black rounded-2xl p-6 text-center shadow-[4px_4px_0_rgba(0,0,0,0.15)] hover:shadow-[6px_6px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300 no-underline">
				<img src="/images/scaletofreedom.webp" alt="Scale to Freedom Package Sloth" width="128" height="128" loading="eager" decoding="async" class="w-20 h-20 object-contain mx-auto mb-3 group-hover:scale-110 transition-transform duration-300" />
				<div class="inline-block bg-[#FF4D4D] text-white border-2 border-black rounded-full px-4 py-1 text-xs font-black tracking-wide mb-3">SCALE TO FREEDOM</div>
				<h3 class="text-lg font-black text-[#1B1B3D] mb-1" style="font-family:'Inter',system-ui,sans-serif;">11 Books</h3>
				<p class="text-sm text-gray-600 mb-3">The Complete System</p>
				<span class="text-2xl font-black text-[#1B1B3D]">$97</span>
			</a>
		</div>
	</div>
</section>

<!-- Tier Navigation -->
<nav id="tier-nav" class="rl-tier-nav sticky top-16 z-30 border-b-[3px] border-black" aria-label="Library tiers">
	<div class="container mx-auto px-4 flex flex-wrap justify-center gap-3 py-3.5">
		<a href="#starter" data-tier="starter" class="tier-nav-link active" aria-current="true">🌱 Starter</a>
		<a href="#builder" data-tier="builder" class="tier-nav-link">🏗️ Builder</a>
		<a href="#scale" data-tier="scale" class="tier-nav-link">🚀 Scale</a>
	</div>
</nav>

<!-- STARTER TIER -->
<section id="starter" class="tier-section relative py-20 md:py-28 overflow-hidden bg-gradient-to-br from-yellow-50 via-amber-50 to-yellow-50">
	<div class="tier-decor tier-decor--starter" aria-hidden="true">
		<span class="tier-decor__f tier-decor__f--1">🌱</span>
		<span class="tier-decor__f tier-decor__f--2">📕</span>
		<span class="tier-decor__f tier-decor__f--3">✨</span>
	</div>
	<div class="container mx-auto px-4 relative z-10 max-w-5xl">
		<!-- Tier Header -->
		<div class="text-center mb-14 reveal-up">
			<img src="/images/starterpackage.webp" alt="Starter Package Sloth" width="160" height="160" loading="lazy" decoding="async" class="w-28 h-28 object-contain mx-auto mb-6" />
			<div class="inline-flex items-center gap-2 bg-[#FFE066] border-4 border-black rounded-full px-6 py-2 shadow-[4px_4px_0_rgba(0,0,0,0.2)] mb-6">
				<span class="text-2xl">🌱</span>
				<span class="font-black text-lg tracking-wide">TIER 1: STARTER</span>
			</div>
			<h2 class="tier-heading text-3xl sm:text-4xl font-black mb-4 text-[#1B1B3D]">The Foundation</h2>
			<p class="text-lg text-gray-600 max-w-2xl mx-auto">
				The mindset shift and the business model. Stop trading time for money and start building something that can earn while you sleep once you have done the setup and light ongoing care.
			</p>
		</div>

		<!-- Books -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
			<div class="book-card reveal-up group relative bg-white border-4 border-black rounded-2xl p-8 shadow-[6px_6px_0_rgba(0,0,0,0.15)] hover:shadow-[10px_10px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300">
				<div class="absolute -top-3 -left-3 w-10 h-10 bg-[#FFE066] rounded-full border-3 border-black flex items-center justify-center font-black text-lg shadow-[2px_2px_0_rgba(0,0,0,0.2)]">1</div>
				<div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">📕</div>
				<h3 class="text-xl font-black mb-2" style="font-family:'Inter',system-ui,sans-serif;">Don't Do Anything</h3>
				<p class="text-sm text-gray-500 italic mb-3">The Strategic Sloth's Guide to Building Smart, Lazy Income Online</p>
				<p class="text-gray-700">Your income engine. Learn how to build digital products that can sell on autopilot after setup: no course to record, no clients to chase. You do not need a big audience on day one, but you still put the product and page in front of people who already look for that problem.</p>
			</div>

			<div class="book-card reveal-up group relative bg-white border-4 border-black rounded-2xl p-8 shadow-[6px_6px_0_rgba(0,0,0,0.15)] hover:shadow-[10px_10px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300" style="animation-delay:100ms">
				<div class="absolute -top-3 -left-3 w-10 h-10 bg-[#FFE066] rounded-full border-3 border-black flex items-center justify-center font-black text-lg shadow-[2px_2px_0_rgba(0,0,0,0.2)]">2</div>
				<div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">📗</div>
				<h3 class="text-xl font-black mb-2" style="font-family:'Inter',system-ui,sans-serif;">Design Your Exit</h3>
				<p class="text-sm text-gray-500 italic mb-3">Biohack Your Mind, Reclaim Your Time, and Build a Life That Doesn't Need Escaping</p>
				<p class="text-gray-700">The operating system upgrade for the person behind the business. Mental, physical, and structural changes so your income actually translates into freedom.</p>
			</div>
		</div>

		<!-- CTA -->
		<div class="text-center reveal-up">
			<a href={CHECKOUT_STARTER} class="lemonsqueezy-button inline-flex items-center gap-2 bg-[#1B1B3D] text-white font-bold px-8 py-4 rounded-xl border-4 border-black shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-200 text-lg">
				🌱 Get the Starter Package - $17
			</a>
		</div>
	</div>
</section>

<!-- BUILDER TIER -->
<section id="builder" class="tier-section relative py-20 md:py-28 overflow-hidden bg-gradient-to-br from-blue-50 via-sky-50 to-blue-50">
	<div class="tier-decor tier-decor--builder" aria-hidden="true">
		<span class="tier-decor__f tier-decor__f--1">🗺️</span>
		<span class="tier-decor__f tier-decor__f--2">🏠</span>
		<span class="tier-decor__f tier-decor__f--3">🔒</span>
	</div>
	<div class="container mx-auto px-4 relative z-10 max-w-5xl">
		<!-- Tier Header -->
		<div class="text-center mb-14 reveal-up">
			<img src="/images/bestvalue.webp" alt="Best Value Package Sloth" width="160" height="160" loading="lazy" decoding="async" class="w-28 h-28 object-contain mx-auto mb-6" />
			<div class="inline-flex items-center gap-2 bg-[#4D9FFF] text-white border-4 border-black rounded-full px-6 py-2 shadow-[4px_4px_0_rgba(0,0,0,0.2)] mb-6">
				<span class="text-2xl">🏗️</span>
				<span class="font-black text-lg tracking-wide">TIER 2: BUILDER</span>
			</div>
			<h2 class="tier-heading text-3xl sm:text-4xl font-black mb-4 text-[#1B1B3D]">The Sovereign Architecture</h2>
			<p class="text-lg text-gray-600 max-w-2xl mx-auto">
				You've got the income. Now protect it, structure it, and position yourself so no single government or institution has full control over your financial life.
			</p>
			<p class="text-sm text-gray-400 mt-3 italic">Includes everything in the Starter tier, plus 4 additional books.</p>
		</div>

		<!-- Books -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
			<div class="book-card reveal-up group relative bg-white border-4 border-black rounded-2xl p-8 shadow-[6px_6px_0_rgba(0,0,0,0.15)] hover:shadow-[10px_10px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300">
				<div class="absolute -top-3 -left-3 w-10 h-10 bg-[#4D9FFF] text-white rounded-full border-3 border-black flex items-center justify-center font-black text-lg shadow-[2px_2px_0_rgba(0,0,0,0.2)]">3</div>
				<div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">🗺️</div>
				<h3 class="text-xl font-black mb-2" style="font-family:'Inter',system-ui,sans-serif;">The Freedom Blueprint</h3>
				<p class="text-sm text-gray-500 italic mb-3">Your Sovereignty Architecture</p>
				<p class="text-gray-700">The strategic overview. Understand the Five Flags Theory and how residency, citizenship, banking, business, and asset storage work together as a system.</p>
			</div>

			<div class="book-card reveal-up group relative bg-white border-4 border-black rounded-2xl p-8 shadow-[6px_6px_0_rgba(0,0,0,0.15)] hover:shadow-[10px_10px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300" style="animation-delay:100ms">
				<div class="absolute -top-3 -left-3 w-10 h-10 bg-[#4D9FFF] text-white rounded-full border-3 border-black flex items-center justify-center font-black text-lg shadow-[2px_2px_0_rgba(0,0,0,0.2)]">4</div>
				<div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">🔒</div>
				<h3 class="text-xl font-black mb-2" style="font-family:'Inter',system-ui,sans-serif;">Strategic Privacy & Tax Positioning</h3>
				<p class="text-sm text-gray-500 italic mb-3">Anonymity and Zero-Tax Strategy</p>
				<p class="text-gray-700">Earning money is step one. Keeping it is step two. Legally minimize your tax burden and protect your personal information from exposure.</p>
			</div>

			<div class="book-card reveal-up group relative bg-white border-4 border-black rounded-2xl p-8 shadow-[6px_6px_0_rgba(0,0,0,0.15)] hover:shadow-[10px_10px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300" style="animation-delay:200ms">
				<div class="absolute -top-3 -left-3 w-10 h-10 bg-[#4D9FFF] text-white rounded-full border-3 border-black flex items-center justify-center font-black text-lg shadow-[2px_2px_0_rgba(0,0,0,0.2)]">5</div>
				<div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">🏠</div>
				<h3 class="text-xl font-black mb-2" style="font-family:'Inter',system-ui,sans-serif;">Residency Without Relocation</h3>
				<p class="text-sm text-gray-500 italic mb-3">Legal Residence with Minimal Stays</p>
				<p class="text-gray-700">You don't have to move to Panama to be a tax resident of Panama. Programs worldwide that grant legal residency with minimal physical presence requirements.</p>
			</div>

			<div class="book-card reveal-up group relative bg-white border-4 border-black rounded-2xl p-8 shadow-[6px_6px_0_rgba(0,0,0,0.15)] hover:shadow-[10px_10px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300" style="animation-delay:300ms">
				<div class="absolute -top-3 -left-3 w-10 h-10 bg-[#4D9FFF] text-white rounded-full border-3 border-black flex items-center justify-center font-black text-lg shadow-[2px_2px_0_rgba(0,0,0,0.2)]">6</div>
				<div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">🌐</div>
				<h3 class="text-xl font-black mb-2" style="font-family:'Inter',system-ui,sans-serif;">Global Business Jurisdictions Guide</h3>
				<p class="text-sm text-gray-500 italic mb-3">Setup and Scale Globally</p>
				<p class="text-gray-700">Where your business lives matters. The top jurisdictions for incorporating an international business, with real cost comparisons and setup processes.</p>
			</div>
		</div>

		<!-- CTA -->
		<div class="text-center reveal-up">
			<a href={CHECKOUT_BEST_VALUE} class="lemonsqueezy-button inline-flex items-center gap-2 bg-[#4D9FFF] text-white font-bold px-8 py-4 rounded-xl border-4 border-black shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-200 text-lg">
				🏗️ Get the Best Value Package - $47
			</a>
			<p class="text-sm text-gray-400 mt-3">Includes all Starter + Builder books</p>
		</div>
	</div>
</section>

<!-- SCALE TO FREEDOM TIER -->
<section id="scale" class="tier-section relative py-20 md:py-28 overflow-hidden bg-gradient-to-br from-red-50 via-orange-50 to-red-50">
	<div class="tier-decor tier-decor--scale" aria-hidden="true">
		<span class="tier-decor__f tier-decor__f--1">🏦</span>
		<span class="tier-decor__f tier-decor__f--2">🛡️</span>
		<span class="tier-decor__f tier-decor__f--3">🛂</span>
	</div>
	<div class="container mx-auto px-4 relative z-10 max-w-5xl">
		<!-- Tier Header -->
		<div class="text-center mb-14 reveal-up">
			<img src="/images/scaletofreedom.webp" alt="Scale to Freedom Package Sloth" width="160" height="160" loading="lazy" decoding="async" class="w-28 h-28 object-contain mx-auto mb-6" />
			<div class="inline-flex items-center gap-2 bg-[#FF4D4D] text-white border-4 border-black rounded-full px-6 py-2 shadow-[4px_4px_0_rgba(0,0,0,0.2)] mb-6">
				<span class="text-2xl">🚀</span>
				<span class="font-black text-lg tracking-wide">TIER 3: SCALE TO FREEDOM</span>
			</div>
			<h2 class="tier-heading text-3xl sm:text-4xl font-black mb-4 text-[#1B1B3D]">The Full Toolkit</h2>
			<p class="text-lg text-gray-600 max-w-2xl mx-auto">
				Banking infrastructure, asset protection across jurisdictions, and second passports. The financial and legal architecture to operate globally with complete independence.
			</p>
			<p class="text-sm text-gray-400 mt-3 italic">Includes everything in Starter + Builder tiers, plus 5 additional books.</p>
		</div>

		<!-- Books -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
			<div class="book-card reveal-up group relative bg-white border-4 border-black rounded-2xl p-8 shadow-[6px_6px_0_rgba(0,0,0,0.15)] hover:shadow-[10px_10px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300">
				<div class="absolute -top-3 -left-3 w-10 h-10 bg-[#FF4D4D] text-white rounded-full border-3 border-black flex items-center justify-center font-black text-lg shadow-[2px_2px_0_rgba(0,0,0,0.2)]">7</div>
				<div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">🏦</div>
				<h3 class="text-xl font-black mb-2" style="font-family:'Inter',system-ui,sans-serif;">Global Banking Systems for Entrepreneurs</h3>
				<p class="text-sm text-gray-500 italic mb-3">Strategic Banking Layers and Alternatives</p>
				<p class="text-gray-700">You can't operate globally with a single domestic bank account. The entire offshore and fintech banking landscape, from free platforms to Swiss private banks.</p>
			</div>

			<div class="book-card reveal-up group relative bg-white border-4 border-black rounded-2xl p-8 shadow-[6px_6px_0_rgba(0,0,0,0.15)] hover:shadow-[10px_10px_0_rgba(0,0,0,0.1)] hover:-translate-y-1 transition-all duration-300" style="animation-delay:100ms">
				<div class="absolute -top-3 -left-3 w-10 h-10 bg-[#FF4D4D] text-white rounded-full border-3 border-black flex items-center justify-center font-black text-lg shadow-[2px_2px_0_rgba(0,0,0,0.2)]">8</div>
				<div class="text-4xl mb-4 group-hover:scale-110 transition-transform duration-300">💳</div>
