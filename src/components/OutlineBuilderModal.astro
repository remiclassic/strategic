// ─── STATE ────────────────────────────────────────────────────────────────────

let outlineVariant = 0;
let lastOutlineHash = '';

// ─── HELPERS ─────────────────────────────────────────────────────────────────

function pick<T>(arr: T[], idx: number): T { return arr[idx % arr.length]; }
function interp(s: string, t: string): string { return s.replace(/\{topic\}/g, t); }
function cap(s: string): string { return s.charAt(0).toUpperCase() + s.slice(1); }

// ─── GENERATION ──────────────────────────────────────────────────────────────

function generateOutline(inputs: OutlineInputs) {
  const { topic, audience, productType, depth, variant } = inputs;
  const t = topic.trim() || 'your topic';

  const titlesArr = titlePrefixes[productType]?.[audience] ?? titlePrefixes['guide']['busy_professionals'];
  const title = interp(pick(titlesArr, variant), cap(t));

  const subtitleArrDeep = subtitlesByTypeDepth[productType]?.[depth] ?? subtitlesByTypeDepth['guide']['standard'];
  const subtitle = interp(pick(subtitleArrDeep, variant), t);

  const promisesArr = promisesByType[productType] ?? promisesByType['guide'];
  const promise = interp(pick(promisesArr, variant), t);

  const sectionsMatrix = sectionsByTypeDepth[productType]?.[depth] ?? sectionsByTypeDepth['guide']['standard'];
  const sections = pick(sectionsMatrix, variant);

  const bonusMatrix = bonusIdeasByType[productType] ?? bonusIdeasByType['guide'];
  const bonuses = pick(bonusMatrix, variant);

  const finalPage = finalPageByType[productType] ?? finalPageByType['guide'];

  return { title, subtitle, promise, sections, bonuses, finalPage };
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function renderOutline(data: ReturnType<typeof generateOutline>) {
  const empty = document.getElementById('outline-empty-state')!;
  const result = document.getElementById('outline-result')!;

  (document.getElementById('outline-result-title') as HTMLElement).textContent = data.title;
  (document.getElementById('outline-result-subtitle') as HTMLElement).textContent = data.subtitle;
  (document.getElementById('outline-promise') as HTMLElement).textContent = data.promise;

  const sectionsEl = document.getElementById('outline-sections')!;
  sectionsEl.innerHTML = data.sections.map((s, i) => `
    <li class="flex items-start gap-2.5 text-sm text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">
      <span class="mt-0.5 w-6 h-6 rounded-full bg-[#F0EEFF] border-2 border-black flex items-center justify-center text-xs font-black text-[#1B1B3D] shrink-0">${i + 1}</span>
      <span class="font-medium leading-relaxed pt-0.5">${s}</span>
    </li>`).join('');

  const bonusesEl = document.getElementById('outline-bonuses')!;
  bonusesEl.innerHTML = data.bonuses.map(b => `
    <li class="flex items-start gap-2 text-sm text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">
      <span class="mt-1 w-4 h-4 rounded-full bg-[#2ECC71] border-2 border-black flex items-center justify-center text-white text-xs shrink-0">+</span>
      <span class="font-medium leading-relaxed">${b}</span>
    </li>`).join('');

  (document.getElementById('outline-final-page') as HTMLElement).textContent = data.finalPage;

  empty.classList.add('hidden');
  result.classList.remove('hidden');
  result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ─── MODAL CONTROL ────────────────────────────────────────────────────────────

const overlay = document.getElementById('outline-modal-overlay') as HTMLElement;
const card = document.getElementById('outline-modal-card') as HTMLElement;
const closeBtn = document.getElementById('outline-modal-close') as HTMLButtonElement;

function openModal(prefillTopic?: string) {
  if (prefillTopic) {
    (document.getElementById('outline-topic') as HTMLInputElement).value = prefillTopic;
  }
  overlay.classList.remove('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-95');
  card.classList.add('scale-100');
  document.body.style.overflow = 'hidden';
  (card.querySelector('.modal-scroll') as HTMLElement).scrollTop = 0;
}

function closeModal() {
  overlay.classList.add('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-100');
  card.classList.add('scale-95');
  document.body.style.overflow = '';
}

(window as any).openOutlineBuilderModal = openModal;

closeBtn.addEventListener('click', closeModal);
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

// ─── FORM INTERACTIONS ────────────────────────────────────────────────────────

document.querySelectorAll('.outline-topic-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    (document.getElementById('outline-topic') as HTMLInputElement).value = (chip as HTMLElement).dataset.topic ?? '';
  });
});

document.getElementById('outline-generate-btn')!.addEventListener('click', () => {
  const icon = document.getElementById('outline-btn-icon') as HTMLElement;
  const text = document.getElementById('outline-btn-text') as HTMLElement;
  const btn = document.getElementById('outline-generate-btn') as HTMLButtonElement;
  icon.textContent = '⏳'; text.textContent = 'Building...'; btn.disabled = true;

  setTimeout(() => {
    const topic = (document.getElementById('outline-topic') as HTMLInputElement).value;
    const audience = (document.getElementById('outline-audience') as HTMLSelectElement).value;
    const productType = (document.getElementById('outline-type') as HTMLSelectElement).value;
    const depth = (document.getElementById('outline-depth') as HTMLSelectElement).value;

    const hash = `${topic}|${audience}|${productType}|${depth}`;
    if (hash !== lastOutlineHash) { outlineVariant = 0; lastOutlineHash = hash; }

    const data = generateOutline({ topic, audience, productType, depth, variant: outlineVariant });
    renderOutline(data);
    icon.textContent = '📐'; text.textContent = 'Build My Outline'; btn.disabled = false;
  }, 500);
});

document.getElementById('outline-regen-btn')!.addEventListener('click', () => {
  const topic = (document.getElementById('outline-topic') as HTMLInputElement).value;
  const audience = (document.getElementById('outline-audience') as HTMLSelectElement).value;
  const productType = (document.getElementById('outline-type') as HTMLSelectElement).value;
  const depth = (document.getElementById('outline-depth') as HTMLSelectElement).value;
  outlineVariant++;
  const data = generateOutline({ topic, audience, productType, depth, variant: outlineVariant });
  renderOutline(data);
});

document.getElementById('outline-copy-btn')!.addEventListener('click', () => {
  const title = (document.getElementById('outline-result-title') as HTMLElement).textContent ?? '';
  const subtitle = (document.getElementById('outline-result-subtitle') as HTMLElement).textContent ?? '';
  const promise = (document.getElementById('outline-promise') as HTMLElement).textContent ?? '';
  const sections = Array.from(document.querySelectorAll('#outline-sections li')).map((li, i) => `${i + 1}. ${li.querySelector('span:last-child')?.textContent?.trim()}`).join('\n');
  const bonuses = Array.from(document.querySelectorAll('#outline-bonuses li')).map(li => `+ ${li.querySelector('span:last-child')?.textContent?.trim()}`).join('\n');
  const finalPage = (document.getElementById('outline-final-page') as HTMLElement).textContent ?? '';
  const text = `PDF OUTLINE\n\n${title}\n${subtitle}\n\nPromise: ${promise}\n\nOutline:\n${sections}\n\nBonus Ideas:\n${bonuses}\n\nFinal Page:\n${finalPage}\n\nGenerated by Strategic Sloth Outline Builder`;
  navigator.clipboard.writeText(text).then(() => {
    const el = document.getElementById('outline-copy-text') as HTMLElement;
    el.textContent = 'Copied!';
    setTimeout(() => { el.textContent = 'Copy Outline'; }, 2000);
  });
});

document.getElementById('outline-narriaflow-btn')!.addEventListener('click', () => {
  closeModal();
});

})();
</script>
