// ─── STATE ────────────────────────────────────────────────────────────────────

let angleVariant = 0;
let lastAngleHash = '';
let currentTopic = '';

// ─── HELPERS ─────────────────────────────────────────────────────────────────

function pick<T>(arr: T[], idx: number): T { return arr[idx % arr.length]; }
function interp(s: string, t: string): string { return s.replace(/\{topic\}/g, t); }
function cap(s: string): string { return s.charAt(0).toUpperCase() + s.slice(1); }

// ─── GENERATION ──────────────────────────────────────────────────────────────

function generateAngles(inputs: AngleData) {
  const { tone, outcome, audience, topic, variant } = inputs;
  const t = topic.trim() || 'your topic';

  const hookSets = hooksByToneOutcome[tone]?.[outcome] ?? hooksByToneOutcome['practical']['save_time'];
  const hookSet = pick(hookSets, variant);
  const hooks = hookSet.map(h => interp(h, t));

  const promisesRaw = promisesByToneAudience[tone]?.[audience] ?? promisesByToneAudience['practical']['busy_professionals'];
  const promises = promisesRaw.map(p => interp(p, t));

  const positionsRaw = positioningByToneAudience[tone]?.[audience] ?? positioningByToneAudience['practical']['busy_professionals'];
  const positions = positionsRaw.map(p => interp(p, t));

  const bestPick = bestPickMap[tone]?.[outcome] ?? 'Hook 1 + Promise 1 + Positioning 1. A straightforward combination that clearly communicates what this product does and who it is for.';

  const label = `${cap(t)} / ${audience.replace('_',' ')} / ${tone.replace('_',' ')}`;

  return { hooks, promises, positions, bestPick, label };
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function renderAngles(data: ReturnType<typeof generateAngles>) {
  const empty = document.getElementById('angle-empty-state')!;
  const result = document.getElementById('angle-result')!;

  (document.getElementById('angle-result-label') as HTMLElement).textContent = data.label;

  const makeList = (items: string[]) =>
    items.map((item, i) => `
      <li class="flex items-start gap-2.5 text-sm text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">
        <span class="mt-0.5 w-5 h-5 rounded-full bg-[#1B1B3D] border-2 border-black flex items-center justify-center text-white text-xs font-black shrink-0">${i + 1}</span>
        <span class="font-medium leading-relaxed">${item}</span>
      </li>`).join('');

  (document.getElementById('angle-hooks') as HTMLElement).innerHTML = makeList(data.hooks);
  (document.getElementById('angle-promises') as HTMLElement).innerHTML = makeList(data.promises);
  (document.getElementById('angle-positions') as HTMLElement).innerHTML = makeList(data.positions);
  (document.getElementById('angle-best-pick') as HTMLElement).textContent = data.bestPick;

  empty.classList.add('hidden');
  result.classList.remove('hidden');
  result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ─── MODAL CONTROL ────────────────────────────────────────────────────────────

const overlay = document.getElementById('angle-modal-overlay') as HTMLElement;
const card = document.getElementById('angle-modal-card') as HTMLElement;
const closeBtn = document.getElementById('angle-modal-close') as HTMLButtonElement;

function openModal(prefillTopic?: string) {
  if (prefillTopic) {
    (document.getElementById('angle-topic') as HTMLInputElement).value = prefillTopic;
  }
  overlay.classList.remove('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-95');
  card.classList.add('scale-100');
  document.body.style.overflow = 'hidden';
  (card.querySelector('.modal-scroll') as HTMLElement).scrollTop = 0;
}

function closeModal() {
  overlay.classList.add('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-100');
  card.classList.add('scale-95');
  document.body.style.overflow = '';
}

(window as any).openAngleGeneratorModal = openModal;

closeBtn.addEventListener('click', closeModal);
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

// ─── FORM INTERACTIONS ────────────────────────────────────────────────────────

document.querySelectorAll('.angle-topic-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    (document.getElementById('angle-topic') as HTMLInputElement).value = (chip as HTMLElement).dataset.topic ?? '';
  });
});

document.getElementById('angle-generate-btn')!.addEventListener('click', () => {
  const icon = document.getElementById('angle-btn-icon') as HTMLElement;
  const text = document.getElementById('angle-btn-text') as HTMLElement;
  const btn = document.getElementById('angle-generate-btn') as HTMLButtonElement;

  icon.textContent = '⏳';
  text.textContent = 'Generating...';
  btn.disabled = true;

  setTimeout(() => {
    const topic = (document.getElementById('angle-topic') as HTMLInputElement).value;
    const audience = (document.getElementById('angle-audience') as HTMLSelectElement).value;
    const outcome = (document.getElementById('angle-outcome') as HTMLSelectElement).value;
    const tone = (document.getElementById('angle-tone') as HTMLSelectElement).value;

    currentTopic = topic;
    const hash = `${topic}|${audience}|${outcome}|${tone}`;
    if (hash !== lastAngleHash) { angleVariant = 0; lastAngleHash = hash; }

    const data = generateAngles({ topic, audience, outcome, tone, variant: angleVariant });
    renderAngles(data);

    icon.textContent = '🎯';
    text.textContent = 'Generate Angles';
    btn.disabled = false;
  }, 500);
});

document.getElementById('angle-regen-btn')!.addEventListener('click', () => {
  const topic = (document.getElementById('angle-topic') as HTMLInputElement).value;
  const audience = (document.getElementById('angle-audience') as HTMLSelectElement).value;
  const outcome = (document.getElementById('angle-outcome') as HTMLSelectElement).value;
  const tone = (document.getElementById('angle-tone') as HTMLSelectElement).value;
  angleVariant++;
  const data = generateAngles({ topic, audience, outcome, tone, variant: angleVariant });
  renderAngles(data);
});

document.getElementById('angle-copy-btn')!.addEventListener('click', () => {
  const hooks = Array.from(document.querySelectorAll('#angle-hooks li span:last-child')).map(el => el.textContent).join('\n');
  const promises = Array.from(document.querySelectorAll('#angle-promises li span:last-child')).map(el => el.textContent).join('\n');
  const positions = Array.from(document.querySelectorAll('#angle-positions li span:last-child')).map(el => el.textContent).join('\n');
  const best = (document.getElementById('angle-best-pick') as HTMLElement).textContent;
  const text = `PRODUCT ANGLE GENERATOR\n\nHook Ideas:\n${hooks}\n\nPromise Angles:\n${promises}\n\nPositioning Directions:\n${positions}\n\nBest Pick:\n${best}\n\nGenerated by Strategic Sloth`;
  navigator.clipboard.writeText(text).then(() => {
    const el = document.getElementById('angle-copy-text') as HTMLElement;
    el.textContent = 'Copied!';
    setTimeout(() => { el.textContent = 'Copy All'; }, 2000);
  });
});

document.getElementById('angle-use-outline')!.addEventListener('click', () => {
  closeModal();
  setTimeout(() => {
    if (typeof (window as any).openOutlineBuilderModal === 'function') {
      (window as any).openOutlineBuilderModal(currentTopic || (document.getElementById('angle-topic') as HTMLInputElement).value);
    }
  }, 200);
});

})();
