---
const audienceOptions = [
  { value: "beginners",          label: "Beginners" },
  { value: "freelancers",        label: "Freelancers" },
  { value: "creators",           label: "Creators" },
  { value: "busy_professionals", label: "Busy Professionals" },
  { value: "students",           label: "Students" },
];

const toneOptions = [
  { value: "simple",     label: "Simple" },
  { value: "confident",  label: "Confident" },
  { value: "friendly",   label: "Friendly" },
  { value: "direct",     label: "Direct" },
];
---

<!-- Sales Page Helper Modal -->
<div
  id="sales-modal-overlay"
  class="fixed inset-0 z-[210] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
  aria-modal="true"
  role="dialog"
  aria-labelledby="sales-modal-title"
>
  <div
    id="sales-modal-card"
    class="relative w-full max-w-3xl bg-[#FFFBF2] border-[3px] border-black rounded-[24px] overflow-hidden shadow-[6px_6px_0_#000] scale-95 transition-transform duration-200"
  >
  <div class="modal-scroll max-h-[90vh] overflow-y-auto overflow-x-hidden">
    <!-- Close -->
    <button
      id="sales-modal-close"
      type="button"
      class="sticky top-4 float-right mr-4 z-10 w-9 h-9 flex items-center justify-center bg-white border-2 border-black rounded-full shadow-[2px_2px_0_#000] hover:bg-[#FFD600] transition-colors duration-150 text-black font-black text-lg leading-none"
      aria-label="Close"
    >✕</button>

    <div class="p-7 sm:p-8 clear-both">
      <!-- Header -->
      <div class="flex items-center gap-3 mb-1">
        <div class="w-10 h-10 rounded-xl border-2 border-black bg-[#FFFBF2] flex items-center justify-center text-xl shadow-[2px_2px_0_#000]">✍️</div>
        <div>
          <div class="flex items-center gap-2 mb-0.5">
            <h2 id="sales-modal-title" class="text-xl font-black text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">Sales Page Helper</h2>
            <span class="inline-flex items-center gap-1 bg-[#2ECC71] text-white text-xs font-black border-2 border-black rounded-full px-2.5 py-0.5 shadow-[2px_2px_0_#000]">
              <span class="w-1.5 h-1.5 rounded-full bg-white inline-block animate-pulse"></span>
              LIVE
            </span>
          </div>
          <p class="text-sm text-[#5C5C7A]" style="font-family:'Inter',system-ui,sans-serif;">Turn your product into simple, persuasive sales copy. No marketing degree needed.</p>
        </div>
      </div>

      <div class="h-px bg-black/10 my-6"></div>

      <!-- Form -->
      <div class="space-y-5">
        <!-- Product name + audience -->
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="sales-product-name" style="font-family:'Inter',system-ui,sans-serif;">Product name</label>
            <input
              id="sales-product-name"
              type="text"
              placeholder="e.g. The Freelance Starter Kit"
              class="w-full px-4 py-3 rounded-xl border-2 border-black bg-white text-[#1B1B3D] placeholder-[#B0B0C8] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] focus:border-[#FFD600] transition-all duration-150"
              style="font-family:'Inter',system-ui,sans-serif;"
            />
          </div>
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="sales-audience" style="font-family:'Inter',system-ui,sans-serif;">Who is it for?</label>
            <div class="relative">
              <select id="sales-audience" class="w-full appearance-none px-4 py-3 pr-10 rounded-xl border-2 border-black bg-white text-[#1B1B3D] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] transition-all duration-150 cursor-pointer" style="font-family:'Inter',system-ui,sans-serif;">
                {audienceOptions.map(o => <option value={o.value}>{o.label}</option>)}
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Desired result + frustration -->
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="sales-result" style="font-family:'Inter',system-ui,sans-serif;">Desired result</label>
            <input
              id="sales-result"
              type="text"
              placeholder="What do they want to achieve?"
              class="w-full px-4 py-3 rounded-xl border-2 border-black bg-white text-[#1B1B3D] placeholder-[#B0B0C8] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] focus:border-[#FFD600] transition-all duration-150"
              style="font-family:'Inter',system-ui,sans-serif;"
            />
          </div>
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="sales-frustration" style="font-family:'Inter',system-ui,sans-serif;">Biggest frustration</label>
            <input
              id="sales-frustration"
              type="text"
              placeholder="What are they struggling with?"
              class="w-full px-4 py-3 rounded-xl border-2 border-black bg-white text-[#1B1B3D] placeholder-[#B0B0C8] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] focus:border-[#FFD600] transition-all duration-150"
              style="font-family:'Inter',system-ui,sans-serif;"
            />
          </div>
        </div>

        <!-- Tone -->
        <div>
          <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="sales-tone" style="font-family:'Inter',system-ui,sans-serif;">Tone</label>
          <div class="relative max-w-xs">
            <select id="sales-tone" class="w-full appearance-none px-4 py-3 pr-10 rounded-xl border-2 border-black bg-white text-[#1B1B3D] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] transition-all duration-150 cursor-pointer" style="font-family:'Inter',system-ui,sans-serif;">
              {toneOptions.map(o => <option value={o.value}>{o.label}</option>)}
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </div>
        </div>

        <!-- Generate -->
        <button
          id="sales-generate-btn"
          type="button"
          class="w-full flex items-center justify-center gap-2 bg-[#FFD600] text-black font-black text-base px-8 py-4 rounded-xl border-[3px] border-black shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-150"
          style="font-family:'Inter',system-ui,sans-serif;"
        >
          <span id="sales-btn-icon">✍️</span>
          <span id="sales-btn-text">Write My Sales Copy</span>
        </button>
      </div>

      <!-- Empty state -->
      <div id="sales-empty-state" class="mt-6 flex flex-col items-center justify-center py-10 border-2 border-dashed border-[#D0D0E4] rounded-xl bg-white/60">
        <span class="text-4xl mb-3">📄</span>
        <p class="font-bold text-[#8888A4] text-center" style="font-family:'Inter',system-ui,sans-serif;">Your sales copy will appear here</p>
        <p class="text-sm text-[#B0B0C8] mt-1" style="font-family:'Inter',system-ui,sans-serif;">Fill in the fields above and hit Write</p>
      </div>

      <!-- Result -->
      <div id="sales-result" class="mt-6 hidden">
        <div class="border-[3px] border-black rounded-2xl overflow-hidden bg-white shadow-[4px_4px_0_#000]">
          <!-- Result header -->
          <div class="bg-[#1B1B3D] px-6 py-4 flex items-center justify-between gap-3">
            <div>
              <p class="text-[#FFD600] text-xs font-black uppercase tracking-widest mb-0.5" style="font-family:'Inter',system-ui,sans-serif;">Your Sales Copy</p>
              <p id="sales-result-label" class="text-white font-bold text-sm" style="font-family:'Inter',system-ui,sans-serif;"></p>
            </div>
            <span class="shrink-0 inline-flex items-center gap-1 bg-[#FFD600] text-black text-xs font-black border-2 border-black rounded-full px-3 py-1">
              ✦ Ready
            </span>
          </div>

          <div class="p-6 sm:p-7 space-y-4">
            <!-- Headline -->
            <div class="bg-[#FFF3CD] border-2 border-black rounded-xl p-4">
              <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">Headline</p>
              <p id="sales-headline-output" class="text-xl font-black text-[#1B1B3D] leading-tight" style="font-family:'Inter',system-ui,sans-serif;"></p>
            </div>

            <!-- Subheadline -->
            <div class="bg-[#FFFBF2] border-2 border-black rounded-xl p-4">
              <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">Subheadline</p>
              <p id="sales-subheadline-output" class="font-bold text-[#1B1B3D] leading-relaxed" style="font-family:'Inter',system-ui,sans-serif;"></p>
            </div>

            <!-- Hook -->
            <div class="bg-white border-2 border-black rounded-xl p-4">
              <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-2" style="font-family:'Inter',system-ui,sans-serif;">Hook Paragraph</p>
              <p id="sales-hook-output" class="font-medium text-[#1B1B3D] text-sm leading-relaxed" style="font-family:'Inter',system-ui,sans-serif;"></p>
            </div>

            <!-- What you get -->
            <div class="bg-[#E3F9ED] border-2 border-black rounded-xl p-4">
              <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-3" style="font-family:'Inter',system-ui,sans-serif;">What You Get</p>
              <ul id="sales-bullets-output" class="space-y-2"></ul>
            </div>

            <!-- Why it works -->
            <div class="bg-[#F0EEFF] border-2 border-black rounded-xl p-4">
              <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">Why This Works</p>
              <p id="sales-why-output" class="font-medium text-[#1B1B3D] text-sm leading-relaxed" style="font-family:'Inter',system-ui,sans-serif;"></p>
            </div>

            <!-- CTA -->
            <div class="bg-[#FFD600] border-2 border-black rounded-xl p-4">
              <p class="text-xs font-black uppercase tracking-widest text-black mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">CTA Line</p>
              <p id="sales-cta-output" class="font-black text-[#1B1B3D] text-lg leading-tight" style="font-family:'Inter',system-ui,sans-serif;"></p>
            </div>

            <!-- FAQ -->
            <div class="bg-[#E3F4FF] border-2 border-black rounded-xl p-4">
              <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-3" style="font-family:'Inter',system-ui,sans-serif;">FAQ Starters</p>
              <ul id="sales-faq-output" class="space-y-2"></ul>
            </div>

            <!-- Action buttons -->
            <div class="flex flex-col sm:flex-row gap-3 pt-1">
              <a
                href="#narriaflow"
                id="sales-narriaflow-btn"
                class="flex-1 inline-flex items-center justify-center gap-2 bg-[#1B1B3D] text-white font-black text-sm px-5 py-3.5 rounded-xl border-[3px] border-black shadow-[3px_3px_0_#000] hover:shadow-[1px_1px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-150"
                style="font-family:'Inter',system-ui,sans-serif;"
              >
                🚀 Use in NarriaFlow
              </a>
              <button
                id="sales-copy-btn"
                type="button"
                class="inline-flex items-center justify-center gap-2 bg-white text-[#1B1B3D] font-bold text-sm px-5 py-3.5 rounded-xl border-[3px] border-black shadow-[3px_3px_0_#000] hover:shadow-[1px_1px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-150"
                style="font-family:'Inter',system-ui,sans-serif;"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
                <span id="sales-copy-text">Copy Sales Page</span>
              </button>
              <button
                id="sales-regen-btn"
                type="button"
                class="inline-flex items-center justify-center gap-2 bg-white text-[#1B1B3D] font-bold text-sm px-5 py-3.5 rounded-xl border-[3px] border-black shadow-[3px_3px_0_#000] hover:shadow-[1px_1px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-150"
                style="font-family:'Inter',system-ui,sans-serif;"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Regenerate
              </button>
            </div>

            <p class="text-xs text-[#B0B0C8] text-center pt-1" style="font-family:'Inter',system-ui,sans-serif;">
              NarriaFlow will let you publish this copy directly onto a product page when it launches.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</div>

