---
---

<div
	id="sticky-cta-bar"
	class="fixed bottom-0 left-0 right-0 z-[45] border-t-2 border-black bg-[#FFFDF7] shadow-[0_-6px_24px_rgba(0,0,0,0.12)] transition-transform duration-300 ease-out pb-[env(safe-area-inset-bottom,0)] translate-y-full pointer-events-none"
	aria-hidden="true"
>
	<div class="container-custom mx-auto flex flex-col gap-2 px-4 py-3 sm:flex-row sm:items-center sm:justify-center sm:gap-4 max-w-3xl">
		<a
			href="#get-started"
			class="sticky-cta-primary flex min-h-[48px] flex-1 items-center justify-center rounded-xl border-2 border-black bg-[#2C2D5D] px-4 py-3 text-center text-base font-black text-white transition-colors hover:bg-[#1B1B3D] sm:flex-none sm:min-w-[200px]"
		>
			Get started
		</a>
		<a
			href="#book-offer"
			class="flex min-h-[48px] flex-1 items-center justify-center rounded-xl border-2 border-black bg-[#FFD600] px-4 py-3 text-center text-base font-black text-[#1B1B3D] transition-colors hover:bg-[#FFE44D] sm:flex-none sm:min-w-[200px]"
		>
			$5 starter guide
		</a>
	</div>
</div>

<script>
	const bar = document.getElementById('sticky-cta-bar');
	if (!bar) {
		// no-op
	} else {
		const hero = document.getElementById('hero');
		const showAfterPx = () => Math.min((hero?.offsetHeight ?? 420) * 0.35, 320);
		const footerReserve = 220;
		let ticking = false;
		let lastY = window.scrollY;

		function setStickyCtaHeightPx(px) {
			document.documentElement.style.setProperty('--sticky-cta-height', `${px}px`);
		}

		function updateBar() {
			const y = window.scrollY;
			const doc = document.documentElement;
			const nearBottom = y + window.innerHeight >= doc.scrollHeight - footerReserve;
			const pastHero = y > showAfterPx();

			if (pastHero && !nearBottom) {
				bar.classList.remove('translate-y-full', 'pointer-events-none');
				bar.setAttribute('aria-hidden', 'false');
				requestAnimationFrame(() => {
					setStickyCtaHeightPx(bar.offsetHeight);
				});
			} else {
				bar.classList.add('translate-y-full', 'pointer-events-none');
				bar.setAttribute('aria-hidden', 'true');
				setStickyCtaHeightPx(0);
			}
			lastY = y;
			ticking = false;
		}

		window.addEventListener(
			'scroll',
			() => {
				if (!ticking) {
					requestAnimationFrame(updateBar);
					ticking = true;
				}
			},
			{ passive: true },
		);
		window.addEventListener('resize', () => {
			lastY = window.scrollY;
			updateBar();
			if (!bar.classList.contains('translate-y-full')) {
				requestAnimationFrame(() => setStickyCtaHeightPx(bar.offsetHeight));
			}
		});
		updateBar();
	}
</script>
