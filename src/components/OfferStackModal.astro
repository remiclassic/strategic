// ─── STATE ────────────────────────────────────────────────────────────────────

let offerVariant = 0;
let lastOfferHash = '';

// ─── HELPERS ─────────────────────────────────────────────────────────────────

function pick<T>(arr: T[], idx: number): T { return arr[idx % arr.length]; }
function interp(s: string, name: string, type: string): string {
  return s.replace(/\{name\}/g, name).replace(/\{type\}/g, type);
}
function cap(s: string): string { return s.charAt(0).toUpperCase() + s.slice(1); }
function labelAudience(a: string): string {
  const m: Record<string, string> = { beginners: 'Beginners', freelancers: 'Freelancers', creators: 'Creators', busy_professionals: 'Busy Professionals', students: 'Students' };
  return m[a] ?? a;
}
function labelType(t: string): string {
  const m: Record<string, string> = { checklist: 'Checklist', guide: 'Guide', workbook: 'Workbook', template_pack: 'Template Pack', starter_kit: 'Starter Kit', planner: 'Planner' };
  return m[t] ?? t;
}

// ─── GENERATION ──────────────────────────────────────────────────────────────

function generateOffer(inputs: OfferInputs) {
  const { productName, productType, audience, variant } = inputs;
  const priceRange = inputs.priceRange;

  const displayName = productName.trim() || 'Your Product';
  const displayType = labelType(productType);

  const nameArr = offerNamePrefixes[productType]?.[audience] ?? offerNamePrefixes['guide']['beginners'];
  const offerName = interp(pick(nameArr, variant), displayName, displayType);

  const promiseArr = corePromises[productType]?.[audience] ?? corePromises['guide']['beginners'];
  const promise = interp(pick(promiseArr, variant), displayName, displayType);

  const whatArr = whatTheyGet[productType] ?? whatTheyGet['guide'];
  const what = pick(whatArr, variant);

  const allBonuses = bonusesByType[productType] ?? bonusesByType['guide'];
  const bonusCount = priceRange === 'high' ? 4 : priceRange === 'mid' ? 3 : 2;
  const bonuses = allBonuses.slice(variant % 2, variant % 2 + bonusCount).concat(
    allBonuses.slice(0, Math.max(0, bonusCount - allBonuses.length + (variant % 2)))
  ).slice(0, bonusCount);

  const [priceLow, priceHigh] = priceValues[priceRange] ?? [29, 49];
  const mainPrice = priceRange === 'high' ? priceLow : priceRange === 'mid' ? Math.round((priceLow + priceHigh) / 2) : priceHigh;
  const bonusTotal = bonuses.reduce((s, b) => s + b.value, 0);
  const totalValue = mainPrice + bonusTotal;

  const urgencyArr = urgencyLines[audience] ?? urgencyLines['beginners'];
  const urgency = pick(urgencyArr, variant);

  const positionArr = bundlePositioning[productType] ?? bundlePositioning['guide'];
  const positioning = interp(pick(positionArr, variant), displayName, displayType);

  const label = `${displayName} / ${labelAudience(audience)} / ${displayType}`;

  return { offerName, promise, what, bonuses, mainPrice, bonusTotal, totalValue, urgency, positioning, label, priceRange };
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function renderOffer(data: ReturnType<typeof generateOffer>) {
  const empty = document.getElementById('offer-empty-state')!;
  const result = document.getElementById('offer-result')!;

  (document.getElementById('offer-result-label') as HTMLElement).textContent = data.label;
  (document.getElementById('offer-name-output') as HTMLElement).textContent = data.offerName;
  (document.getElementById('offer-promise-output') as HTMLElement).textContent = data.promise;
  (document.getElementById('offer-what-output') as HTMLElement).textContent = data.what;

  const bonusesEl = document.getElementById('offer-bonuses-output')!;
  bonusesEl.innerHTML = data.bonuses.map(b => `
    <li class="flex items-start justify-between gap-3 text-sm text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">
      <span class="flex items-start gap-2 font-medium leading-relaxed">
        <span class="mt-0.5 w-5 h-5 rounded-full bg-[#2ECC71] border-2 border-black flex items-center justify-center text-white text-xs font-black shrink-0">+</span>
        ${b.name}
      </span>
      <span class="font-black text-[#2ECC71] shrink-0">$${b.value}</span>
    </li>`).join('');

  const stackEl = document.getElementById('offer-stack-output')!;
  const [priceLow, priceHigh] = [data.mainPrice, data.mainPrice];
  void priceLow; void priceHigh;
  stackEl.innerHTML = `
    <div class="flex justify-between text-sm font-medium text-[#1B1B3D] py-1.5 border-b border-black/10" style="font-family:'Inter',system-ui,sans-serif;">
      <span>Main Product</span>
      <span class="font-black">$${data.mainPrice}</span>
    </div>
    ${data.bonuses.map(b => `
    <div class="flex justify-between text-sm font-medium text-[#1B1B3D] py-1.5 border-b border-black/10" style="font-family:'Inter',system-ui,sans-serif;">
      <span>${b.name.split('(')[0].trim()}</span>
      <span class="font-black">$${b.value}</span>
    </div>`).join('')}
    <div class="flex justify-between text-sm py-1.5 border-b border-black/10 text-[#5C5C7A]" style="font-family:'Inter',system-ui,sans-serif;">
      <span class="font-bold">Total Value</span>
      <span class="font-black line-through">$${data.totalValue}</span>
    </div>
    <div class="flex justify-between text-base font-black text-[#1B1B3D] pt-2" style="font-family:'Inter',system-ui,sans-serif;">
      <span>Your Price</span>
      <span class="text-[#2ECC71]">$${data.mainPrice}</span>
    </div>`;

  (document.getElementById('offer-urgency-output') as HTMLElement).textContent = data.urgency;
  (document.getElementById('offer-positioning-output') as HTMLElement).textContent = data.positioning;

  empty.classList.add('hidden');
  result.classList.remove('hidden');
  result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ─── MODAL CONTROL ────────────────────────────────────────────────────────────

const overlay = document.getElementById('offer-modal-overlay') as HTMLElement;
const card = document.getElementById('offer-modal-card') as HTMLElement;
const closeBtn = document.getElementById('offer-modal-close') as HTMLButtonElement;

function openModal() {
  overlay.classList.remove('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-95');
  card.classList.add('scale-100');
  document.body.style.overflow = 'hidden';
  (card.querySelector('.modal-scroll') as HTMLElement).scrollTop = 0;
}

function closeModal() {
  overlay.classList.add('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-100');
  card.classList.add('scale-95');
  document.body.style.overflow = '';
}

(window as any).openOfferStackModal = openModal;

closeBtn.addEventListener('click', closeModal);
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

// ─── FORM INTERACTIONS ────────────────────────────────────────────────────────

function getInputs(): OfferInputs {
  return {
    productName: (document.getElementById('offer-product-name') as HTMLInputElement).value,
    productType: (document.getElementById('offer-type') as HTMLSelectElement).value,
    audience: (document.getElementById('offer-audience') as HTMLSelectElement).value,
    painPoint: (document.getElementById('offer-pain') as HTMLInputElement).value,
    priceRange: (document.getElementById('offer-price') as HTMLSelectElement).value,
    variant: offerVariant,
  };
}

document.getElementById('offer-generate-btn')!.addEventListener('click', () => {
  const icon = document.getElementById('offer-btn-icon') as HTMLElement;
  const text = document.getElementById('offer-btn-text') as HTMLElement;
  const btn = document.getElementById('offer-generate-btn') as HTMLButtonElement;
  icon.textContent = '⏳'; text.textContent = 'Building...'; btn.disabled = true;

  setTimeout(() => {
    const inputs = getInputs();
    const hash = `${inputs.productName}|${inputs.productType}|${inputs.audience}|${inputs.priceRange}`;
    if (hash !== lastOfferHash) { offerVariant = 0; lastOfferHash = hash; inputs.variant = 0; }
    const data = generateOffer(inputs);
    renderOffer(data);
    icon.textContent = '📦'; text.textContent = 'Build My Offer'; btn.disabled = false;
  }, 500);
});

document.getElementById('offer-regen-btn')!.addEventListener('click', () => {
  offerVariant++;
  const inputs = getInputs();
  inputs.variant = offerVariant;
  const data = generateOffer(inputs);
  renderOffer(data);
});

document.getElementById('offer-copy-btn')!.addEventListener('click', () => {
  const name = (document.getElementById('offer-name-output') as HTMLElement).textContent ?? '';
  const promise = (document.getElementById('offer-promise-output') as HTMLElement).textContent ?? '';
  const what = (document.getElementById('offer-what-output') as HTMLElement).textContent ?? '';
  const bonuses = Array.from(document.querySelectorAll('#offer-bonuses-output li')).map(li => `+ ${li.querySelector('span:first-child span:last-child')?.textContent?.trim()}`).join('\n');
  const stack = Array.from(document.querySelectorAll('#offer-stack-output div')).map(d => d.textContent?.replace(/\s+/g, ' ').trim()).join('\n');
  const urgency = (document.getElementById('offer-urgency-output') as HTMLElement).textContent ?? '';
  const positioning = (document.getElementById('offer-positioning-output') as HTMLElement).textContent ?? '';
  const text = `OFFER STACK\n\nOffer Name:\n${name}\n\nCore Promise:\n${promise}\n\nWhat They Get:\n${what}\n\nBonus Ideas:\n${bonuses}\n\nValue Stack:\n${stack}\n\nUrgency Angle:\n${urgency}\n\nBundle Positioning:\n${positioning}\n\nGenerated by Strategic Sloth Offer Stack Builder`;
  navigator.clipboard.writeText(text).then(() => {
    const el = document.getElementById('offer-copy-text') as HTMLElement;
    el.textContent = 'Copied!';
    setTimeout(() => { el.textContent = 'Copy Offer'; }, 2000);
  });
});

document.getElementById('offer-narriaflow-btn')!.addEventListener('click', () => {
  closeModal();
});

})();
</script>
