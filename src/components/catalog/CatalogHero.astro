---
// No props needed — content is static
---

<section class="catalog-hero">
  <div class="catalog-hero__inner">
    <div class="catalog-hero__badge">🦥 Strategic Sloth Library</div>
    <h1 class="catalog-hero__heading">
      Build Your Income System,<br />One Step at a Time
    </h1>
    <p class="catalog-hero__subtext">
      Simple guides. No fluff. No overwhelm.<br class="hide-mobile" />
      Just clear steps that work.
    </p>
    <div class="catalog-hero__actions">
      <a href="#bundles" class="cta-primary">View Bundles</a>
      <a href="#books" class="cta-secondary">Browse All Books</a>
    </div>
    <p class="catalog-hero__note">15 guides · 3 bundles · instant digital delivery</p>
    <p class="catalog-hero__context">
      These are practical digital PDF guides for building and selling digital products. No income guarantees, just clear steps that work when you put them into practice.<br class="hide-mobile" />
      Looking for the sovereignty &amp; freedom system? <a href="/reading-guide" class="context-link">See the Freedom Library →</a>
    </p>
  </div>
</section>

<style>
  .catalog-hero {
    background-color: #FFFDF7;
    border-bottom: 2px solid #000;
    padding: 6rem 1.25rem 4rem;
    text-align: center;
  }

  .catalog-hero__inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .catalog-hero__badge {
    display: inline-block;
    background: #FFD600;
    border: 2px solid #000;
    box-shadow: 3px 3px 0 #000;
    border-radius: 999px;
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.3rem 1rem;
    margin-bottom: 1.25rem;
    color: #1B1B3D;
  }

  .catalog-hero__heading {
    font-family: 'Bangers', cursive;
    font-size: clamp(2.4rem, 6vw, 4rem);
    letter-spacing: 0.02em;
    line-height: 1.08;
    color: #1B1B3D;
    margin: 0 0 1rem;
  }

  .catalog-hero__subtext {
    font-family: 'Inter', sans-serif;
    font-size: clamp(1rem, 2.5vw, 1.2rem);
    color: #4a4a6a;
    line-height: 1.6;
    margin: 0 0 2rem;
  }

  .catalog-hero__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #FFD600;
    color: #1B1B3D;
    font-family: 'Bangers', cursive;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    padding: 0.75rem 2rem;
    border: 3px solid #000;
    box-shadow: 4px 4px 0 #000;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
    min-height: 44px;
  }

  .cta-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #000;
  }

  .cta-primary:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    color: #1B1B3D;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    padding: 0.75rem 1.75rem;
    border: 2px solid #1B1B3D;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
    min-height: 44px;
  }

  .cta-secondary:hover {
    background: #1B1B3D;
    color: #fff;
  }

  .catalog-hero__note {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #8888aa;
    margin: 0;
    letter-spacing: 0.03em;
  }

  .catalog-hero__context {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #9999bb;
    margin: 0.75rem 0 0;
    line-height: 1.5;
  }

  .context-link {
    color: #1B1B3D;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.15s ease;
  }

  .context-link:hover {
    opacity: 0.7;
  }

  @media (max-width: 480px) {
    .catalog-hero {
      padding: 5rem 1rem 3rem;
    }

    .hide-mobile {
      display: none;
    }

    .catalog-hero__actions {
      flex-direction: column;
      align-items: center;
    }

    .cta-primary,
    .cta-secondary {
      width: 100%;
      max-width: 280px;
    }
  }
</style>
