---
const sampleProducts = [
  { emoji: '📋', title: "The Freelancer's Client Onboarding Kit", type: 'Starter Kit' },
  { emoji: '🗺️', title: 'Beginner Solo Travel Checklist', type: 'Checklist' },
  { emoji: '💸', title: 'Simple Money Tracker for Busy People', type: 'Workbook' },
];
---

<section class="tools-hero relative overflow-hidden border-b-[3px] border-black bg-[#FFD600] py-20 md:py-28">
  <div class="tools-hero-pattern absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div class="tools-float-layer absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <span class="tools-float tools-float--1">🛠️</span>
    <span class="tools-float tools-float--2">✨</span>
    <span class="tools-float tools-float--3">📄</span>
    <span class="tools-float tools-float--4">🦥</span>
    <span class="tools-float tools-float--5">💡</span>
    <span class="tools-float tools-float--6">⚡</span>
  </div>
  <div class="tools-z-layer absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <svg class="tools-z tools-z--1" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"
      ><path
        d="M8 12H32L12 28H32"
        stroke="#2C2D5D"
        stroke-width="4"
        stroke-linecap="round"
        stroke-linejoin="round"></path></svg
    >
    <svg class="tools-z tools-z--2" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"
      ><path
        d="M8 12H32L12 28H32"
        stroke="#2C2D5D"
        stroke-width="4"
        stroke-linecap="round"
        stroke-linejoin="round"></path></svg
    >
  </div>

  <div class="container-custom relative z-10 mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Copy -->
      <div>
        <div class="mb-6 flex justify-center lg:justify-start">
          <span
            class="tools-hero-badge inline-flex items-center gap-2 rounded-full border-[3px] border-black bg-white px-4 py-2 text-[#1B1B3D] shadow-[3px_3px_0_#000]"
          >
            <span class="text-base">🛠️</span>
            <span class="text-xs font-extrabold uppercase tracking-widest" style="font-family: Inter, system-ui, sans-serif"
              >Free creator tools</span
            >
          </span>
        </div>

        <h1
          class="tools-hero-title mb-6 text-center text-[clamp(2.4rem,6.5vw,3.75rem)] font-black leading-[1.05] text-[#1B1B3D] lg:text-left"
          style="font-family: Bangers, cursive; letter-spacing: 0.02em;"
        >
          Turn What You Know Into<br />
          <span class="tools-hero-title-accent italic">Something You Can Sell</span>
        </h1>

        <p
          class="mb-4 text-center text-lg leading-relaxed text-[#2a2a4a] sm:text-xl lg:text-left"
          style="font-family: Inter, system-ui, sans-serif;"
        >
          Simple tools to turn skills and messy ideas into digital products without overthinking every step.
        </p>
        <p class="mb-8 text-center text-base text-[#5c5c7a] lg:text-left" style="font-family: Inter, system-ui, sans-serif;">
          No big audience required on day one. No guru status. One useful idea, then the patient work to shape and ship it.
        </p>

        <div class="mb-8 flex flex-wrap justify-center gap-2 lg:justify-start">
          <span class="tools-stat-pill"><span class="tools-stat-emoji">⚡</span> Live tools</span>
          <span class="tools-stat-pill"><span class="tools-stat-emoji">🔓</span> No account</span>
          <span class="tools-stat-pill"><span class="tools-stat-emoji">🎯</span> PDF-focused</span>
        </div>

        <div class="flex flex-col gap-3 sm:flex-row sm:justify-center lg:justify-start">
          <a href="#idea-builder" class="tools-cta-primary">
            <span class="tools-cta-shine" aria-hidden="true"></span>
            <span>⚡ Try the Idea Builder</span>
          </a>
          <a href="#narriaflow" class="tools-cta-secondary">Get Early Access →</a>
        </div>

        <p
          class="mt-5 flex items-center justify-center gap-1.5 text-sm text-[#1B1B3D]/65 lg:justify-start"
          style="font-family: Inter, system-ui, sans-serif;"
        >
          <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Free to use · No fluff
        </p>
      </div>

      <!-- Stacked cards -->
      <div class="relative flex min-h-[320px] items-center justify-center lg:min-h-[380px]">
        <div
          class="absolute h-72 w-72 rounded-full border-2 border-[#000]/10 bg-[#fff]/30"
          style="top: 50%; left: 50%; transform: translate(-50%, -50%);"
        >
        </div>

        <div class="relative mx-auto w-full max-w-sm">
          {
            sampleProducts.map((product, i) => (
              <div
                class:list={[
                  'tools-stack-card absolute inset-x-0 rounded-2xl border-[3px] border-black bg-white p-5 shadow-[4px_4px_0_#000]',
                  i === 0 && '-rotate-3 z-10',
                  i === 1 && 'z-20 rotate-0',
                  i === 2 && 'rotate-2 z-30',
                ]}
                style={`top: ${i * 28}px; margin-left: ${i === 1 ? '16px' : i === 2 ? '8px' : '0'};`}
              >
                <div class="flex items-start gap-3">
                  <span class="text-3xl">{product.emoji}</span>
                  <div>
                    <p class="text-sm font-black leading-tight text-[#1B1B3D]" style="font-family: Inter, system-ui, sans-serif;">
                      {product.title}
                    </p>
                    <span class="mt-1.5 inline-block rounded-full border border-black bg-[#FFD600] px-2 py-0.5 text-xs font-bold">
                      {product.type}
                    </span>
                  </div>
                </div>
              </div>
            ))
          }
          <div class="h-52"></div>
        </div>

        <div
          class="animate-float-badge absolute right-0 top-4 rotate-3 rounded-full border-2 border-black bg-[#2ECC71] px-3 py-1.5 text-xs font-black text-white shadow-[2px_2px_0_#000]"
        >
          ✦ LIVE NOW
        </div>
        <div
          class="tools-badge-soft absolute bottom-8 left-0 -rotate-2 rounded-full border-2 border-black bg-white px-3 py-1.5 text-xs font-bold text-[#1B1B3D] shadow-[2px_2px_0_#000]"
        >
          💡 Start with one idea
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .tools-hero-pattern {
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 5C32 5 34 7 34 9C34 11 32 13 30 13C28 13 26 11 26 9C26 7 28 5 30 5ZM22 14C24 14 26 16 26 18C26 20 24 22 22 22C20 22 18 20 18 18C18 16 20 14 22 14ZM38 14C40 14 42 16 42 18C42 20 40 22 38 22C36 22 34 20 34 18C34 16 36 14 38 14ZM30 23C35 23 39 27 39 32C39 37 35 41 30 41C25 41 21 37 21 32C21 27 25 23 30 23Z' fill='%23FFB800' fill-opacity='0.12'/%3E%3C/svg%3E");
  }

  .tools-float {
    position: absolute;
    font-size: clamp(1.35rem, 3.2vw, 2rem);
    line-height: 1;
    filter: drop-shadow(1px 2px 0 rgba(0, 0, 0, 0.12));
    animation: toolsEmojiFloat 6.5s ease-in-out infinite;
    will-change: transform;
  }
  .tools-float--1 {
    top: 12%;
    left: 6%;
  }
  .tools-float--2 {
    top: 22%;
    right: 10%;
    animation-delay: 0.6s;
  }
  .tools-float--3 {
    bottom: 28%;
    left: 8%;
    animation-delay: 1.1s;
  }
  .tools-float--4 {
    top: 40%;
    right: 18%;
    font-size: clamp(1.6rem, 4vw, 2.35rem);
    animation-delay: 0.2s;
  }
  .tools-float--5 {
    bottom: 14%;
    right: 8%;
    animation-delay: 1.4s;
  }
  .tools-float--6 {
    top: 8%;
    left: 40%;
    animation-delay: 0.9s;
    opacity: 0.85;
  }

  .tools-z {
    position: absolute;
    opacity: 0.07;
    animation: toolsZFloat 8.5s ease-in-out infinite;
  }
  .tools-z--1 {
    top: 20%;
    left: 15%;
    width: 2.25rem;
    height: 2.25rem;
  }
  .tools-z--2 {
    bottom: 25%;
    right: 20%;
    width: 2.75rem;
    height: 2.75rem;
    animation-delay: 3s;
  }

  @keyframes toolsEmojiFloat {
    0%,
    100% {
      transform: translate(0, 0) rotate(-5deg);
    }
    50% {
      transform: translate(4px, -12px) rotate(6deg);
    }
  }

  @keyframes toolsZFloat {
    0%,
    100% {
      transform: translate(0, 0);
      opacity: 0.05;
    }
    50% {
      transform: translate(0, -16px) rotate(3deg);
      opacity: 0.1;
    }
  }

  @keyframes toolsBadgePop {
    0%,
    100% {
      transform: rotate(-1deg) scale(1);
    }
    50% {
      transform: rotate(1deg) scale(1.02);
    }
  }

  .tools-hero-badge {
    animation: toolsBadgePop 3s ease-in-out infinite;
  }

  .tools-hero-title {
    text-shadow: 2px 2px 0 rgba(255, 255, 255, 0.35);
  }

  .tools-hero-title-accent {
    position: relative;
    display: inline-block;
  }
  .tools-hero-title-accent::after {
    content: '';
    position: absolute;
    left: -1%;
    right: -1%;
    bottom: 0.06em;
    height: 0.2em;
    background: linear-gradient(90deg, transparent, rgba(43, 45, 93, 0.16), transparent);
    border-radius: 2px;
    z-index: -1;
    transform: rotate(-1deg);
  }

  .tools-stat-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border-radius: 999px;
    border: 2px solid #000;
    background: rgba(255, 255, 255, 0.55);
    padding: 0.35rem 0.85rem;
    font-size: 0.78rem;
    font-weight: 800;
    color: #1b1b3d;
    box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.1);
    transition: transform 0.15s ease;
  }
  .tools-stat-pill:hover {
    transform: translateY(-2px);
  }

  .tools-stat-emoji {
    display: inline-block;
    animation: toolsStatWiggle 2.5s ease-in-out infinite;
  }
  .tools-stat-pill:nth-child(2) .tools-stat-emoji {
    animation-delay: 0.35s;
  }
  .tools-stat-pill:nth-child(3) .tools-stat-emoji {
    animation-delay: 0.7s;
  }

  @keyframes toolsStatWiggle {
    0%,
    100% {
      transform: rotate(0deg);
    }
    30% {
      transform: rotate(-7deg);
    }
    70% {
      transform: rotate(7deg);
    }
  }

  .tools-cta-primary {
    position: relative;
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 10px;
    border: 3px solid #000;
    background: #2c2d5d;
    padding: 0.75rem 1.75rem;
    font-family: Bangers, cursive;
    font-size: 1.2rem;
    letter-spacing: 0.05em;
    color: #fff;
    text-decoration: none;
    box-shadow: 4px 4px 0 #000;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
  }
  .tools-cta-primary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #000;
  }
  .tools-cta-primary:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
  }

  .tools-cta-shine {
    pointer-events: none;
    position: absolute;
    top: -50%;
    left: -50%;
    height: 200%;
    width: 200%;
    background: linear-gradient(
      45deg,
      transparent 40%,
      rgba(255, 255, 255, 0.12) 50%,
      transparent 60%
    );
    transform: rotate(25deg);
    animation: toolsCtaShine 4s ease-in-out infinite;
  }

  @keyframes toolsCtaShine {
    0%,
    100% {
      transform: translateX(-55%) rotate(25deg);
    }
    50% {
      transform: translateX(35%) rotate(25deg);
    }
  }

  .tools-cta-secondary {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    border: 3px solid #000;
    background: #fff;
    padding: 0.75rem 1.5rem;
    font-weight: 800;
    color: #1b1b3d;
    text-decoration: none;
    box-shadow: 3px 3px 0 #000;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease,
      background 0.15s ease;
  }
  .tools-cta-secondary:hover {
    transform: translate(-2px, -2px);
    box-shadow: 5px 5px 0 #000;
    background: #e3f2ff;
  }

  .tools-stack-card {
    transition: box-shadow 0.2s ease;
  }
  .tools-stack-card:hover {
    box-shadow: 6px 8px 0 #000;
  }

  @keyframes float-badge {
    0%,
    100% {
      transform: translateY(0) rotate(3deg);
    }
    50% {
      transform: translateY(-6px) rotate(3deg);
    }
  }
  .animate-float-badge {
    animation: float-badge 3s ease-in-out infinite;
  }

  .tools-badge-soft {
    animation: toolsSoftBob 3.5s ease-in-out infinite;
  }

  @keyframes toolsSoftBob {
    0%,
    100% {
      transform: translateY(0) rotate(-2deg);
    }
    50% {
      transform: translateY(-5px) rotate(-2deg);
    }
  }

  @media (max-width: 640px) {
    .tools-float--4,
    .tools-float--6 {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tools-float,
    .tools-z,
    .tools-hero-badge,
    .tools-stat-emoji,
    .tools-cta-shine,
    .animate-float-badge,
    .tools-badge-soft,
    .tools-stack-card:hover {
      box-shadow: 4px 4px 0 #000;
    }
    .tools-stat-pill:hover {
      transform: none;
    }
  }
</style>
