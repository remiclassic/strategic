---
// ExitIntentPopup.astro — compact centered modal; fits common mobile viewports without scroll
const specialOffer = {
	title: "Leaving already? 😴",
	intro: "$5 guide first. Not for you? Full refund.",
	kitTitle: "🦥 Lazy Genius Starter Kit",
	kitBlurb: "$5 PDF: lazy-income roadmap. 30 days to try.",
	bonusLabel: "Includes bonus",
	bonusTitle: "Find Your First Product (AI Prompt Kit)",
	bonusBlurb:
		"A simple system that helps you turn your experience into a product idea you can actually build.",
	cta: "Buy Lazy Genius Starter Kit",
	ctaSubtext: "Instant access · 30-day guarantee",
	ctaLink: "https://strategicsloth.lemonsqueezy.com/checkout/buy/5c2ebe0c-f79e-433f-9583-627a417c05fd?embed=1",
	noThanks: "No thanks",
};
---

<div
	id="exit-popup"
	class="exit-popup-root fixed inset-0 z-50 hidden overflow-hidden overscroll-contain bg-black/45"
	role="dialog"
	aria-modal="true"
	aria-label="Special offer"
>
	<div
		class="exit-popup-shell min-h-[100dvh] w-full flex items-center justify-center px-3 py-4 sm:px-6 sm:py-8 box-border pt-[max(1rem,env(safe-area-inset-top))] pb-[max(1rem,env(safe-area-inset-bottom))]"
	>
		<div
			class="exit-popup-frame min-h-0 w-full max-w-[min(100%,520px)] min-w-0 shrink sm:max-w-[600px]"
		>
			<div
				data-exit-popup-card
				class="relative flex w-full max-h-[calc(100dvh-2.25rem-env(safe-area-inset-top)-env(safe-area-inset-bottom))] flex-col overflow-hidden rounded-2xl border-[3px] border-black bg-[#FFF8E7] shadow-[3px_3px_0_0_#000] sm:max-h-[min(88dvh,860px)] sm:rounded-[32px] sm:shadow-[4px_4px_0_0_#000] box-border"
			>
				<button
					id="close-popup"
					type="button"
					class="absolute top-3 right-3 z-10 flex h-10 w-10 items-center justify-center rounded-lg text-2xl leading-none text-black/70 hover:bg-black/5 active:bg-black/10 touch-manipulation sm:top-4 sm:right-4 sm:h-11 sm:w-11"
					aria-label="Close offer"
				>
					×
				</button>

				<!-- Host clips; inner column uses zoom or transform so everything fits without scroll -->
				<div data-exit-popup-fit-host class="min-h-0 w-full overflow-hidden">
					<div
						data-exit-popup-fit-target
						class="flex w-full flex-col px-3.5 pt-12 pb-3 text-center sm:px-8 sm:pt-14 sm:pb-5"
					>
					<header class="w-full min-w-0 space-y-1 px-1 sm:space-y-2 sm:px-3">
						<h2
							class="text-base font-bold leading-tight text-balance text-[#1B1B3D] sm:text-[32px]"
						>
							{specialOffer.title}
						</h2>
						<p
							class="mx-auto max-w-sm text-[11px] leading-snug text-pretty text-[#1B1B3D]/90 sm:max-w-md sm:text-lg sm:leading-snug"
						>
							{specialOffer.intro}
						</p>
					</header>

					<div class="mt-2 flex w-full min-w-0 flex-col items-center gap-2 sm:mt-3 sm:gap-4">
						<div class="mx-auto flex w-[7rem] max-h-[min(9rem,22dvh)] shrink-0 items-center justify-center sm:w-56 sm:max-h-none">
							<img
								src="/images/bookpdf.webp"
								alt="Don't Do Anything - Strategic Sloth Starter Guide"
								width="1024"
								height="1536"
								loading="lazy"
								decoding="async"
								class="mx-auto h-auto max-h-[min(9rem,22dvh)] w-full object-contain rounded-md border-2 border-black bg-white shadow-[3px_4px_0_0_#000] sm:max-h-none sm:rounded-lg sm:shadow-[4px_6px_0_0_#000]"
							/>
						</div>

						<div class="w-full min-w-0 space-y-0.5 px-0.5 sm:space-y-1.5">
							<h3
								class="text-xs font-bold leading-tight text-balance text-[#1B1B3D] sm:text-2xl"
							>
								{specialOffer.kitTitle}
							</h3>
							<p
								class="mx-auto max-w-sm text-[10px] leading-snug text-pretty text-[#1B1B3D]/88 sm:max-w-md sm:text-xl sm:leading-snug"
							>
								{specialOffer.kitBlurb}
							</p>
						</div>

						<div
							class="mt-0.5 w-full max-w-sm rounded-lg border border-black/15 bg-white/70 px-2.5 py-2 text-left sm:max-w-md sm:rounded-xl sm:px-4 sm:py-3.5"
							aria-label="Included bonus"
						>
							<p class="mb-1 text-[8px] font-bold uppercase tracking-[0.1em] text-[#1B1B3D]/55 sm:mb-1.5 sm:text-[10px] sm:tracking-[0.14em]">
								{specialOffer.bonusLabel}
							</p>
							<p class="text-[10px] font-bold leading-snug text-[#1B1B3D] sm:text-sm">
								{specialOffer.bonusTitle}
							</p>
							<p class="mt-1 text-[9px] font-medium leading-snug text-[#1B1B3D]/75 sm:text-xs sm:leading-relaxed">
								{specialOffer.bonusBlurb}
							</p>
						</div>
					</div>

					<div
						class="exit-popup-cta mt-3 w-full space-y-1.5 border-t border-black/10 pt-3 text-center sm:mt-4 sm:space-y-2.5 sm:border-t-0 sm:pt-0"
					>
						<a
							href={specialOffer.ctaLink}
							id="cta-button"
							class="lemonsqueezy-button flex min-h-[44px] w-full items-center justify-center rounded-xl border-[3px] border-black bg-[#FFD600] px-2 py-2.5 text-center text-xs font-bold leading-tight text-black transition-colors hover:bg-[#FFE44D] sm:min-h-[60px] sm:rounded-[16px] sm:px-3 sm:py-5 sm:text-[26px]"
						>
							{specialOffer.cta}
						</a>
						<p
							class="text-center text-[10px] font-medium leading-snug text-[#1B1B3D]/70 sm:text-base"
						>
							{specialOffer.ctaSubtext}
						</p>

						<div class="text-center">
							<button
								type="button"
								id="no-thanks"
								class="text-[10px] text-[#1B1B3D]/50 hover:text-[#1B1B3D]/75 py-2 px-2 min-h-[40px] sm:text-sm sm:min-h-[44px] underline-offset-2 hover:underline"
							>
								{specialOffer.noThanks}
							</button>
						</div>
					</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>

<script>
	let popupShown = false;

	let exitPopupZoomSupported = /** @type {boolean | null} */ (null);
	function exitPopupZoomWorks() {
		if (exitPopupZoomSupported !== null) return exitPopupZoomSupported;
		const el = document.createElement('div');
		el.style.setProperty('zoom', '0.5');
		exitPopupZoomSupported = el.style.zoom === '0.5';
		return exitPopupZoomSupported;
	}

	function clearExitPopupFit() {
		const host = document.querySelector('[data-exit-popup-fit-host]');
		const target = document.querySelector('[data-exit-popup-fit-target]');
		if (host instanceof HTMLElement) {
			host.style.removeProperty('height');
			host.style.removeProperty('overflow');
		}
		if (!(target instanceof HTMLElement)) return;
		target.style.removeProperty('zoom');
		target.style.removeProperty('transform');
		target.style.removeProperty('transform-origin');
		target.style.removeProperty('width');
		target.style.removeProperty('margin-left');
	}

	/**
	 * Fit entire modal column inside max-height with no scrollbars.
	 * Prefers `zoom` (shrinks layout); otherwise transform + fixed host height.
	 */
	function fitExitPopupCard() {
		const popup = document.getElementById('exit-popup');
		const card = document.querySelector('[data-exit-popup-card]');
		const host = document.querySelector('[data-exit-popup-fit-host]');
		const target = document.querySelector('[data-exit-popup-fit-target]');
		if (!popup || popup.classList.contains('hidden')) return;
		if (!(card instanceof HTMLElement) || !(host instanceof HTMLElement) || !(target instanceof HTMLElement)) return;

		clearExitPopupFit();

		const available = card.clientHeight;
		const needed = target.scrollHeight;
		if (needed <= available + 1) return;

		const raw = available / needed;
		const scale = Math.min(1, Math.max(0.58, raw));

		if (exitPopupZoomWorks()) {
			target.style.zoom = String(scale);
			return;
		}

		host.style.height = `${Math.max(1, Math.floor(available))}px`;
		host.style.overflow = 'hidden';
		target.style.transformOrigin = 'top center';
		target.style.transform = `scale(${scale})`;
		target.style.width = `${(100 / scale).toFixed(5)}%`;
		target.style.marginLeft = `${((1 - 1 / scale) * 50).toFixed(4)}%`;
	}

	let fitExitPopupRaf = 0;
	function scheduleFitExitPopup() {
		cancelAnimationFrame(fitExitPopupRaf);
		fitExitPopupRaf = requestAnimationFrame(() => {
			fitExitPopupCard();
			fitExitPopupRaf = requestAnimationFrame(fitExitPopupCard);
		});
	}

	function showPopup() {
		if (!popupShown) {
			const popup = document.getElementById('exit-popup');
			if (popup) popup.classList.remove('hidden');
			popupShown = true;
			scheduleFitExitPopup();
			if (document.fonts?.ready) {
				document.fonts.ready.then(() => scheduleFitExitPopup());
			}
		}
	}

	function hidePopup() {
		const popup = document.getElementById('exit-popup');
		if (popup) popup.classList.add('hidden');
		clearExitPopupFit();
	}

	window.addEventListener('resize', () => {
		const popup = document.getElementById('exit-popup');
		if (popup && !popup.classList.contains('hidden')) {
			scheduleFitExitPopup();
		}
	});

	document.addEventListener('mouseleave', (e) => {
		if (e.clientY <= 0 && !popupShown) {
			showPopup();
		}
	});

	/** Mobile / touch: fast scroll-up (often “back to URL bar”) suggests exit intent */
	const coarsePointer = window.matchMedia('(pointer: coarse)').matches;
	let lastScrollY = window.scrollY;
	window.addEventListener(
		'scroll',
		() => {
			if (!coarsePointer || popupShown) {
				lastScrollY = window.scrollY;
				return;
			}
			const y = window.scrollY;
			if (lastScrollY - y > 100 && y > 520) {
				showPopup();
			}
			lastScrollY = y;
		},
		{ passive: true },
	);

	document.getElementById('close-popup')?.addEventListener('click', hidePopup);

	document.getElementById('exit-popup')?.addEventListener('click', (e) => {
		const t = e.target;
		if (!(t instanceof Element)) return;
		if (!t.closest('[data-exit-popup-card]')) {
			hidePopup();
		}
	});

	document.getElementById('no-thanks')?.addEventListener('click', hidePopup);

	document.getElementById('cta-button')?.addEventListener('click', hidePopup);
</script>

<style>
	.comic-card {
		transition: all 0.3s ease-out;
		border: 3px solid black;
		box-shadow: 4px 4px 0 rgba(0, 0, 0, 0.2);
	}

	.comic-card:hover .comic-bubble {
		transform: rotate(2deg) scale(1.05);
	}

	.comic-card:hover .comic-icon {
		transform: rotate(-15deg) scale(1.1);
	}

	@keyframes bounce-slow {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-5px);
		}
	}

	.animate-bounce-slow {
		animation: bounce-slow 3s ease-in-out infinite;
	}

	@keyframes bounce-horizontal {
		0%,
		100% {
			transform: translateX(0);
		}
		50% {
			transform: translateX(5px);
		}
	}

	.animate-bounce-horizontal {
		animation: bounce-horizontal 1.5s ease-in-out infinite;
	}
</style>
