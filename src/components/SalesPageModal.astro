// ─── STATE ────────────────────────────────────────────────────────────────────

let salesVariant = 0;
let lastSalesHash = '';

// ─── HELPERS ─────────────────────────────────────────────────────────────────

function pick<T>(arr: T[], idx: number): T { return arr[idx % arr.length]; }
function interp(s: string, vars: Record<string, string>): string {
  return s.replace(/\{(\w+)\}/g, (_, k) => vars[k] ?? `{${k}}`);
}
function labelAudience(a: string): string {
  const m: Record<string, string> = { beginners: 'Beginners', freelancers: 'Freelancers', creators: 'Creators', busy_professionals: 'Busy Professionals', students: 'Students' };
  return m[a] ?? a;
}

// ─── GENERATION ──────────────────────────────────────────────────────────────

function generateSalesPage(inputs: SalesInputs) {
  const { productName, audience, desiredResult, frustration: _frustration, tone, variant } = inputs;

  const name = productName.trim() || 'this product';
  const result = desiredResult.trim() || 'reach your goal';
  const audienceLabel = labelAudience(audience);

  const vars = { name, result, audience: audienceLabel };

  const headlineArr = headlines[tone]?.[audience] ?? headlines['simple']['beginners'];
  const headline = interp(pick(headlineArr, variant), vars);

  const subArr = subheadlines[tone] ?? subheadlines['simple'];
  const subheadline = interp(pick(subArr, variant), vars);

  const hookArr = hookParagraphs[tone]?.[audience] ?? hookParagraphs['simple']['beginners'];
  const hook = interp(pick(hookArr, variant), vars);

  const bulletMatrix = bulletSetsByTone[tone] ?? bulletSetsByTone['simple'];
  const bullets = pick(bulletMatrix, variant);

  const whyArr = whyItWorks[tone] ?? whyItWorks['simple'];
  const why = interp(pick(whyArr, variant), vars);

  const ctaArr = ctaLines[tone] ?? ctaLines['simple'];
  const cta = pick(ctaArr, variant);

  const faqs = faqStartersByAudience[audience] ?? faqStartersByAudience['beginners'];

  const label = `${name} / ${audienceLabel} / ${tone}`;

  return { headline, subheadline, hook, bullets, why, cta, faqs, label };
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function renderSalesPage(data: ReturnType<typeof generateSalesPage>) {
  const empty = document.getElementById('sales-empty-state')!;
  const result = document.getElementById('sales-result')!;

  (document.getElementById('sales-result-label') as HTMLElement).textContent = data.label;
  (document.getElementById('sales-headline-output') as HTMLElement).textContent = data.headline;
  (document.getElementById('sales-subheadline-output') as HTMLElement).textContent = data.subheadline;
  (document.getElementById('sales-hook-output') as HTMLElement).textContent = data.hook;

  const bulletsEl = document.getElementById('sales-bullets-output')!;
  bulletsEl.innerHTML = data.bullets.map(b => `
    <li class="flex items-start gap-2.5 text-sm text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">
      <span class="mt-0.5 w-5 h-5 rounded-full bg-[#2ECC71] border-2 border-black flex items-center justify-center text-white text-xs font-black shrink-0">✓</span>
      <span class="font-medium leading-relaxed">${b}</span>
    </li>`).join('');

  (document.getElementById('sales-why-output') as HTMLElement).textContent = data.why;
  (document.getElementById('sales-cta-output') as HTMLElement).textContent = data.cta;

  const faqEl = document.getElementById('sales-faq-output')!;
  faqEl.innerHTML = data.faqs.map((f, i) => `
    <li class="flex items-start gap-2.5 text-sm text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">
      <span class="mt-0.5 font-black text-[#8888A4] shrink-0">Q${i + 1}.</span>
      <span class="font-medium leading-relaxed">${f}</span>
    </li>`).join('');

  empty.classList.add('hidden');
  result.classList.remove('hidden');
  result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ─── MODAL CONTROL ────────────────────────────────────────────────────────────

const overlay = document.getElementById('sales-modal-overlay') as HTMLElement;
const card = document.getElementById('sales-modal-card') as HTMLElement;
const closeBtn = document.getElementById('sales-modal-close') as HTMLButtonElement;

function openModal() {
  overlay.classList.remove('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-95');
  card.classList.add('scale-100');
  document.body.style.overflow = 'hidden';
  (card.querySelector('.modal-scroll') as HTMLElement).scrollTop = 0;
}

function closeModal() {
  overlay.classList.add('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-100');
  card.classList.add('scale-95');
  document.body.style.overflow = '';
}

(window as any).openSalesPageModal = openModal;

closeBtn.addEventListener('click', closeModal);
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

// ─── FORM INTERACTIONS ────────────────────────────────────────────────────────

function getInputs(): SalesInputs {
  return {
    productName:   (document.getElementById('sales-product-name') as HTMLInputElement).value,
    audience:      (document.getElementById('sales-audience') as HTMLSelectElement).value,
    desiredResult: (document.getElementById('sales-result') as HTMLInputElement).value,
    frustration:   (document.getElementById('sales-frustration') as HTMLInputElement).value,
    tone:          (document.getElementById('sales-tone') as HTMLSelectElement).value,
    variant: salesVariant,
  };
}

document.getElementById('sales-generate-btn')!.addEventListener('click', () => {
  const icon = document.getElementById('sales-btn-icon') as HTMLElement;
  const text = document.getElementById('sales-btn-text') as HTMLElement;
  const btn = document.getElementById('sales-generate-btn') as HTMLButtonElement;
  icon.textContent = '⏳'; text.textContent = 'Writing...'; btn.disabled = true;

  setTimeout(() => {
    const inputs = getInputs();
    const hash = `${inputs.productName}|${inputs.audience}|${inputs.desiredResult}|${inputs.tone}`;
    if (hash !== lastSalesHash) { salesVariant = 0; lastSalesHash = hash; inputs.variant = 0; }
    const data = generateSalesPage(inputs);
    renderSalesPage(data);
    icon.textContent = '✍️'; text.textContent = 'Write My Sales Copy'; btn.disabled = false;
  }, 500);
});

document.getElementById('sales-regen-btn')!.addEventListener('click', () => {
  salesVariant++;
  const inputs = getInputs();
  inputs.variant = salesVariant;
  const data = generateSalesPage(inputs);
  renderSalesPage(data);
});

document.getElementById('sales-copy-btn')!.addEventListener('click', () => {
  const headline    = (document.getElementById('sales-headline-output') as HTMLElement).textContent ?? '';
  const subheadline = (document.getElementById('sales-subheadline-output') as HTMLElement).textContent ?? '';
  const hook        = (document.getElementById('sales-hook-output') as HTMLElement).textContent ?? '';
  const bullets     = Array.from(document.querySelectorAll('#sales-bullets-output li span:last-child')).map(el => `- ${el.textContent?.trim()}`).join('\n');
  const why         = (document.getElementById('sales-why-output') as HTMLElement).textContent ?? '';
  const cta         = (document.getElementById('sales-cta-output') as HTMLElement).textContent ?? '';
  const faqs        = Array.from(document.querySelectorAll('#sales-faq-output li')).map(li => li.textContent?.trim()).join('\n');
  const text = `SALES PAGE COPY\n\nHeadline:\n${headline}\n\nSubheadline:\n${subheadline}\n\nHook:\n${hook}\n\nWhat You Get:\n${bullets}\n\nWhy This Works:\n${why}\n\nCTA:\n${cta}\n\nFAQ Starters:\n${faqs}\n\nGenerated by Strategic Sloth Sales Page Helper`;
  navigator.clipboard.writeText(text).then(() => {
    const el = document.getElementById('sales-copy-text') as HTMLElement;
    el.textContent = 'Copied!';
    setTimeout(() => { el.textContent = 'Copy Sales Page'; }, 2000);
  });
});

document.getElementById('sales-narriaflow-btn')!.addEventListener('click', () => {
  closeModal();
});

})();
</script>
