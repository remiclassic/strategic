		}
		.rl-stat-pill:hover {
			transform: none;
		}
	}
</style>

<script>
	// Scroll-reveal: fade-up book cards and sections as they enter viewport
	const revealObserver = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const delay = entry.target.style.animationDelay;
				if (delay) {
					const ms = parseInt(delay);
					setTimeout(() => entry.target.classList.add('visible'), ms);
				} else {
					entry.target.classList.add('visible');
				}
				revealObserver.unobserve(entry.target);
			}
		});
	}, { threshold: 0.15, rootMargin: '0px 0px -40px 0px' });

	document.querySelectorAll('.reveal-up').forEach(el => revealObserver.observe(el));

		// Active tier nav highlighting (scroll spy: pick the section most in view when several overlap)
	const tierSections = document.querySelectorAll('.tier-section');
	const tierNavLinks = document.querySelectorAll('.tier-nav-link');
	const tierIds = new Set(['starter', 'builder', 'scale']);

	function setActiveTierNav(id) {
		if (!tierIds.has(id)) return;
		tierNavLinks.forEach((link) => {
			const on = link.dataset.tier === id;
			link.classList.toggle('active', on);
			if (on) link.setAttribute('aria-current', 'true');
			else link.removeAttribute('aria-current');
		});
	}

	const navObserver = new IntersectionObserver(
		(entries) => {
			const visible = entries.filter((e) => e.isIntersecting);
			if (!visible.length) return;
			const best = visible.reduce((a, b) =>
				b.intersectionRatio > a.intersectionRatio ? b : a
			);
			setActiveTierNav(best.target.id);
		},
		{
			threshold: [0, 0.1, 0.2, 0.35, 0.5, 0.65, 0.8, 1],
			rootMargin: '-28% 0px -52% 0px',
		}
	);

	tierSections.forEach((section) => navObserver.observe(section));

	const hashId = document.location.hash.replace(/^#/, '');
	if (tierIds.has(hashId)) {
		setActiveTierNav(hashId);
	}

	window.addEventListener('hashchange', () => {
		const id = document.location.hash.replace(/^#/, '');
		if (tierIds.has(id)) setActiveTierNav(id);
	});
</script>
