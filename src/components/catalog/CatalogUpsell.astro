---
interface Props {
  checkoutUrl?: string;
}
const { checkoutUrl = '#' } = Astro.props;
---

<section class="upsell-section">
  <div class="upsell-section__inner">
    <p class="upsell-emoji">🦥</p>
    <h2 class="upsell-heading">Want everything?</h2>
    <p class="upsell-body">
      Get the full system and skip the guesswork.<br />
      All 15 guides. One price. Build, sell, and grow — at your own pace.
    </p>
    <div class="upsell-pricing">
      <span class="upsell-price">$97</span>
      <span class="upsell-anchor">$300+ value → $97 today</span>
    </div>
    <a href={checkoutUrl} class="upsell-cta">
      Get Full Freedom System →
    </a>
    <p class="upsell-guarantee">30-day guarantee · Instant delivery · No subscriptions</p>
  </div>
</section>

<style>
  .upsell-section {
    background: #1B1B3D;
    border-top: 3px solid #000;
    padding: 5rem 1.25rem;
    text-align: center;
  }

  .upsell-section__inner {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .upsell-emoji {
    font-size: 2.5rem;
    margin: 0;
    line-height: 1;
  }

  .upsell-heading {
    font-family: 'Bangers', cursive;
    font-size: clamp(2.2rem, 6vw, 3.2rem);
    letter-spacing: 0.04em;
    color: #FFD600;
    margin: 0;
    line-height: 1.05;
  }

  .upsell-body {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #c8c8e8;
    margin: 0;
    line-height: 1.65;
  }

  .upsell-pricing {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: center;
    margin: 0.25rem 0;
  }

  .upsell-price {
    font-family: 'Bangers', cursive;
    font-size: 3rem;
    letter-spacing: 0.04em;
    color: #fff;
    line-height: 1;
  }

  .upsell-anchor {
    font-family: 'Inter', sans-serif;
    font-size: 0.9rem;
    color: #8888cc;
  }

  .upsell-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #FFD600;
    color: #1B1B3D;
    font-family: 'Bangers', cursive;
    font-size: 1.3rem;
    letter-spacing: 0.06em;
    padding: 0.875rem 2.25rem;
    border: 3px solid #000;
    box-shadow: 4px 4px 0 #000;
    border-radius: 8px;
    text-decoration: none;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
    min-height: 44px;
    margin-top: 0.5rem;
  }

  .upsell-cta:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 #000;
  }

  .upsell-cta:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
  }

  .upsell-guarantee {
    font-family: 'Inter', sans-serif;
    font-size: 0.76rem;
    color: #6666aa;
    margin: 0;
    letter-spacing: 0.03em;
  }
</style>
