    soft:    { text_first: ["PDF cover design, softest cozy typography, pale blush or oat background, gentle rounded font, whisper-quiet palette, warmth you can feel, A4 portrait, flat design"], icon_based: ["PDF cover design, soft cozy icon, pale oat or blush background, gentle font, the gentlest palette, A4 portrait, flat illustration"], illustration: ["PDF cover design, soft cozy illustration, pale and gentle palette, soft rounded font, the warmest quietest design, A4 portrait"], photo_text: ["PDF cover design, soft cozy photography, pale overlay, gentle readable font, warmest and softest palette, A4 portrait"], abstract: ["PDF cover design, soft cozy organic shapes, pale blush or oat background, gentle charcoal font, the warmest and softest palette possible, A4 portrait, flat vector"] },
  },
};

const bestForByVibe: Record<string, string[]> = {
  clean:   ["A clean direction works especially well for professional or practical products where trust and clarity are the first impression. If your audience is busy or skeptical, clean design reduces friction immediately.", "This direction suits products that need to feel reliable and easy to use. The design does not distract from the content."],
  premium: ["A premium direction signals that the product is worth the price before anyone opens it. Works well for higher-priced PDFs, expert-led content, or anything targeting professionals who judge quality quickly.", "This direction is best when you want your product to feel like a considered, high-value resource rather than a quick download."],
  playful: ["A playful direction works well for beginner-friendly products, creative topics, or audiences who are tired of corporate-feeling content. It lowers the barrier and invites people in.", "This direction suits products where warmth and approachability matter more than authority. Good for community-oriented or lifestyle topics."],
  minimal: ["A minimal direction communicates confidence. You are not trying to impress anyone, and that is impressive. Works well for simple, focused products where less is genuinely more.", "This direction suits audiences who appreciate restraint and design fluency. It says 'we did not need to shout about this.'"],
  bold:    ["A bold direction demands attention and signals confidence. Works well for products with a strong point of view, high-energy topics, or audiences who respond to directness and energy.", "This direction suits products that need to stop the scroll. If your product makes a strong promise, the cover should match that energy."],
  cozy:    ["A cozy direction creates an immediate emotional response of safety and warmth. Works especially well for lifestyle, home, parenting, and personal development topics.", "This direction suits audiences who are overwhelmed or stressed. A cozy cover says 'this is manageable and good.'"],
};

// ─── STATE ────────────────────────────────────────────────────────────────────

let coverVariant = 0;
let lastCoverHash = '';

// ─── HELPERS ─────────────────────────────────────────────────────────────────

function pick<T>(arr: T[], idx: number): T { return arr[idx % arr.length]; }
function interp(s: string, t: string): string { return s.replace(/\{topic\}/g, t); }
function cap(s: string): string { return s.charAt(0).toUpperCase() + s.slice(1); }

// ─── GENERATION ──────────────────────────────────────────────────────────────

function generateCoverDirection(inputs: CoverInputs) {
  const { topic, audience: _audience, vibe, visualStyle, colorMood, variant } = inputs;
  const t = topic.trim() || 'your topic';

  const titleArr = conceptTitlesByVibeColor[vibe]?.[colorMood] ?? conceptTitlesByVibeColor['clean']['neutral'];
  const conceptTitle = interp(pick(titleArr, variant), cap(t));

  const summaryArr = visualSummaryByVibeStyle[vibe]?.[visualStyle] ?? visualSummaryByVibeStyle['clean']['text_first'];
  const visualSummary = pick(summaryArr, variant);

  const colorArr = colorDirections[colorMood] ?? colorDirections['neutral'];
  const colorDirection = pick(colorArr, variant);

  const typoArr = typographySuggestions[vibe] ?? typographySuggestions['clean'];
  const typography = pick(typoArr, variant);

  const layoutArr = layoutSuggestions[visualStyle] ?? layoutSuggestions['text_first'];
  const layout = pick(layoutArr, variant);

  const promptNested = imagePromptsByVibeColorStyle[vibe]?.[colorMood]?.[visualStyle];
  const promptArr = promptNested ?? imagePromptsByVibeColorStyle['clean']['warm']['text_first'];
  const rawPrompt = pick(promptArr, variant);
  const imagePrompt = `${rawPrompt}, about: ${t}, digital PDF product cover`;

  const bestForArr = bestForByVibe[vibe] ?? bestForByVibe['clean'];
  const bestFor = pick(bestForArr, variant);

  return { conceptTitle, visualSummary, colorDirection, typography, layout, imagePrompt, bestFor };
}

// ─── RENDER ───────────────────────────────────────────────────────────────────

function renderCoverDirection(data: ReturnType<typeof generateCoverDirection>) {
  const empty = document.getElementById('cover-empty-state')!;
  const result = document.getElementById('cover-result')!;

  (document.getElementById('cover-concept-title') as HTMLElement).textContent = data.conceptTitle;
  (document.getElementById('cover-visual-summary') as HTMLElement).textContent = data.visualSummary;
  (document.getElementById('cover-color-direction') as HTMLElement).textContent = data.colorDirection;
  (document.getElementById('cover-typography') as HTMLElement).textContent = data.typography;
  (document.getElementById('cover-layout') as HTMLElement).textContent = data.layout;
  (document.getElementById('cover-image-prompt') as HTMLElement).textContent = data.imagePrompt;
  (document.getElementById('cover-best-for') as HTMLElement).textContent = data.bestFor;

  empty.classList.add('hidden');
  result.classList.remove('hidden');
  result.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
}

// ─── MODAL CONTROL ────────────────────────────────────────────────────────────

const overlay = document.getElementById('cover-modal-overlay') as HTMLElement;
const card = document.getElementById('cover-modal-card') as HTMLElement;
const closeBtn = document.getElementById('cover-modal-close') as HTMLButtonElement;

function openModal() {
  overlay.classList.remove('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-95');
  card.classList.add('scale-100');
  document.body.style.overflow = 'hidden';
  (card.querySelector('.modal-scroll') as HTMLElement).scrollTop = 0;
}

function closeModal() {
  overlay.classList.add('opacity-0', 'pointer-events-none');
  card.classList.remove('scale-100');
  card.classList.add('scale-95');
  document.body.style.overflow = '';
}

(window as any).openCoverDirectionModal = openModal;

closeBtn.addEventListener('click', closeModal);
overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });

// ─── FORM INTERACTIONS ────────────────────────────────────────────────────────

document.getElementById('cover-generate-btn')!.addEventListener('click', () => {
  const icon = document.getElementById('cover-btn-icon') as HTMLElement;
  const text = document.getElementById('cover-btn-text') as HTMLElement;
  const btn = document.getElementById('cover-generate-btn') as HTMLButtonElement;
  icon.textContent = '⏳'; text.textContent = 'Generating...'; btn.disabled = true;

  setTimeout(() => {
    const topic = (document.getElementById('cover-topic') as HTMLInputElement).value;
    const audience = (document.getElementById('cover-audience') as HTMLSelectElement).value;
    const vibe = (document.getElementById('cover-vibe') as HTMLSelectElement).value;
    const visualStyle = (document.getElementById('cover-style') as HTMLSelectElement).value;
    const colorMood = (document.getElementById('cover-color') as HTMLSelectElement).value;

    const hash = `${topic}|${audience}|${vibe}|${visualStyle}|${colorMood}`;
    if (hash !== lastCoverHash) { coverVariant = 0; lastCoverHash = hash; }

    const data = generateCoverDirection({ topic, audience, vibe, visualStyle, colorMood, variant: coverVariant });
    renderCoverDirection(data);
    icon.textContent = '🎨'; text.textContent = 'Generate Cover Direction'; btn.disabled = false;
  }, 500);
});

document.getElementById('cover-regen-btn')!.addEventListener('click', () => {
  const topic = (document.getElementById('cover-topic') as HTMLInputElement).value;
  const audience = (document.getElementById('cover-audience') as HTMLSelectElement).value;
  const vibe = (document.getElementById('cover-vibe') as HTMLSelectElement).value;
  const visualStyle = (document.getElementById('cover-style') as HTMLSelectElement).value;
  const colorMood = (document.getElementById('cover-color') as HTMLSelectElement).value;
  coverVariant++;
  const data = generateCoverDirection({ topic, audience, vibe, visualStyle, colorMood, variant: coverVariant });
  renderCoverDirection(data);
});

document.getElementById('cover-copy-prompt-btn')!.addEventListener('click', () => {
  const prompt = (document.getElementById('cover-image-prompt') as HTMLElement).textContent ?? '';
  navigator.clipboard.writeText(prompt).then(() => {
    const el = document.getElementById('cover-copy-prompt-text') as HTMLElement;
    el.textContent = 'Copied!';
    setTimeout(() => { el.textContent = 'Copy Prompt'; }, 2000);
  });
});

document.getElementById('cover-copy-brief-btn')!.addEventListener('click', () => {
  const title = (document.getElementById('cover-concept-title') as HTMLElement).textContent ?? '';
  const visual = (document.getElementById('cover-visual-summary') as HTMLElement).textContent ?? '';
  const color = (document.getElementById('cover-color-direction') as HTMLElement).textContent ?? '';
  const typography = (document.getElementById('cover-typography') as HTMLElement).textContent ?? '';
  const layout = (document.getElementById('cover-layout') as HTMLElement).textContent ?? '';
  const prompt = (document.getElementById('cover-image-prompt') as HTMLElement).textContent ?? '';
  const bestFor = (document.getElementById('cover-best-for') as HTMLElement).textContent ?? '';
  const text = `COVER CREATIVE BRIEF\n\n${title}\n\nVisual Direction:\n${visual}\n\nColor Direction:\n${color}\n\nTypography:\n${typography}\n\nLayout:\n${layout}\n\nBest For:\n${bestFor}\n\nAI Image Prompt:\n${prompt}\n\nGenerated by Strategic Sloth Cover Direction Generator`;
  navigator.clipboard.writeText(text).then(() => {
    const el = document.getElementById('cover-copy-brief-text') as HTMLElement;
    el.textContent = 'Copied!';
    setTimeout(() => { el.textContent = 'Copy Full Creative Brief'; }, 2000);
  });
});

})();
</script>
