---
const audienceOptions = [
  { value: "beginners", label: "Beginners" },
  { value: "busy_professionals", label: "Busy Professionals" },
  { value: "freelancers", label: "Freelancers" },
  { value: "creators", label: "Creators" },
  { value: "parents", label: "Parents" },
  { value: "students", label: "Students" },
  { value: "remote_workers", label: "Remote Workers" },
];

const vibeOptions = [
  { value: "clean", label: "Clean" },
  { value: "premium", label: "Premium" },
  { value: "playful", label: "Playful" },
  { value: "minimal", label: "Minimal" },
  { value: "bold", label: "Bold" },
  { value: "cozy", label: "Cozy" },
];

const styleOptions = [
  { value: "text_first", label: "Text-First" },
  { value: "icon_based", label: "Icon-Based" },
  { value: "illustration", label: "Illustration" },
  { value: "photo_text", label: "Photo + Text" },
  { value: "abstract", label: "Abstract Shapes" },
];

const colorMoodOptions = [
  { value: "warm", label: "Warm" },
  { value: "cool", label: "Cool" },
  { value: "neutral", label: "Neutral" },
  { value: "bright", label: "Bright" },
  { value: "soft", label: "Soft" },
];
---

<!-- Cover Direction Generator Modal -->
<div
  id="cover-modal-overlay"
  class="fixed inset-0 z-[210] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-200"
  aria-modal="true"
  role="dialog"
  aria-labelledby="cover-modal-title"
>
  <div
    id="cover-modal-card"
    class="relative w-full max-w-3xl bg-[#FFFBF2] border-[3px] border-black rounded-[24px] overflow-hidden shadow-[6px_6px_0_#000] scale-95 transition-transform duration-200"
  >
  <div class="modal-scroll max-h-[90vh] overflow-y-auto overflow-x-hidden">
    <!-- Close -->
    <button
      id="cover-modal-close"
      type="button"
      class="sticky top-4 float-right mr-4 z-10 w-9 h-9 flex items-center justify-center bg-white border-2 border-black rounded-full shadow-[2px_2px_0_#000] hover:bg-[#FFD600] transition-colors duration-150 text-black font-black text-lg leading-none"
      aria-label="Close"
    >
      ✕
    </button>

    <div class="p-7 sm:p-8 clear-both">
      <!-- Header -->
      <div class="flex items-center gap-3 mb-1">
        <div class="w-10 h-10 rounded-xl border-2 border-black bg-[#E3F4FF] flex items-center justify-center text-xl shadow-[2px_2px_0_#000]">🎨</div>
        <div>
          <div class="flex items-center gap-2 mb-0.5">
            <h2 id="cover-modal-title" class="text-xl font-black text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">Cover Direction Generator</h2>
            <span class="inline-flex items-center gap-1 bg-[#2ECC71] text-white text-xs font-black border-2 border-black rounded-full px-2.5 py-0.5 shadow-[2px_2px_0_#000]">
              <span class="w-1.5 h-1.5 rounded-full bg-white inline-block animate-pulse"></span>
              LIVE
            </span>
          </div>
          <p class="text-sm text-[#5C5C7A]" style="font-family:'Inter',system-ui,sans-serif;">Get a complete visual direction for your PDF cover, plus a ready-to-paste AI image prompt.</p>
        </div>
      </div>

      <div class="h-px bg-black/10 my-6"></div>

      <!-- Form -->
      <div class="space-y-5">
        <!-- Topic + audience row -->
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="cover-topic" style="font-family:'Inter',system-ui,sans-serif;">What is your PDF about?</label>
            <input
              id="cover-topic"
              type="text"
              placeholder="e.g. budgeting, freelancing, fitness..."
              class="w-full px-4 py-3 rounded-xl border-2 border-black bg-white text-[#1B1B3D] placeholder-[#B0B0C8] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] focus:border-[#FFD600] transition-all duration-150"
              style="font-family:'Inter',system-ui,sans-serif;"
            />
          </div>
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="cover-audience" style="font-family:'Inter',system-ui,sans-serif;">Who is it for?</label>
            <div class="relative">
              <select id="cover-audience" class="w-full appearance-none px-4 py-3 pr-10 rounded-xl border-2 border-black bg-white text-[#1B1B3D] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] transition-all duration-150 cursor-pointer" style="font-family:'Inter',system-ui,sans-serif;">
                {audienceOptions.map(o => <option value={o.value}>{o.label}</option>)}
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Visual direction row -->
        <div class="grid sm:grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="cover-vibe" style="font-family:'Inter',system-ui,sans-serif;">Vibe</label>
            <div class="relative">
              <select id="cover-vibe" class="w-full appearance-none px-4 py-3 pr-10 rounded-xl border-2 border-black bg-white text-[#1B1B3D] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] transition-all duration-150 cursor-pointer" style="font-family:'Inter',system-ui,sans-serif;">
                {vibeOptions.map(o => <option value={o.value}>{o.label}</option>)}
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </div>
          </div>
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="cover-style" style="font-family:'Inter',system-ui,sans-serif;">Visual Style</label>
            <div class="relative">
              <select id="cover-style" class="w-full appearance-none px-4 py-3 pr-10 rounded-xl border-2 border-black bg-white text-[#1B1B3D] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] transition-all duration-150 cursor-pointer" style="font-family:'Inter',system-ui,sans-serif;">
                {styleOptions.map(o => <option value={o.value}>{o.label}</option>)}
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </div>
          </div>
          <div>
            <label class="block text-sm font-black text-[#1B1B3D] mb-1.5" for="cover-color" style="font-family:'Inter',system-ui,sans-serif;">Color Mood</label>
            <div class="relative">
              <select id="cover-color" class="w-full appearance-none px-4 py-3 pr-10 rounded-xl border-2 border-black bg-white text-[#1B1B3D] font-medium focus:outline-none focus:ring-2 focus:ring-[#FFD600] transition-all duration-150 cursor-pointer" style="font-family:'Inter',system-ui,sans-serif;">
                {colorMoodOptions.map(o => <option value={o.value}>{o.label}</option>)}
              </select>
              <div class="pointer-events-none absolute inset-y-0 right-3 flex items-center">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
              </div>
            </div>
          </div>
        </div>

        <!-- Generate -->
        <button
          id="cover-generate-btn"
          type="button"
          class="w-full flex items-center justify-center gap-2 bg-[#FFD600] text-black font-black text-base px-8 py-4 rounded-xl border-[3px] border-black shadow-[4px_4px_0_#000] hover:shadow-[2px_2px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-150"
          style="font-family:'Inter',system-ui,sans-serif;"
        >
          <span id="cover-btn-icon">🎨</span>
          <span id="cover-btn-text">Generate Cover Direction</span>
        </button>
      </div>

      <!-- Empty state -->
      <div id="cover-empty-state" class="mt-6 flex flex-col items-center justify-center py-10 border-2 border-dashed border-[#D0D0E4] rounded-xl bg-white/60">
        <span class="text-4xl mb-3">🖼️</span>
        <p class="font-bold text-[#8888A4] text-center" style="font-family:'Inter',system-ui,sans-serif;">Your cover brief will appear here</p>
        <p class="text-sm text-[#B0B0C8] mt-1" style="font-family:'Inter',system-ui,sans-serif;">Fill in the fields above and hit Generate</p>
      </div>

      <!-- Result -->
      <div id="cover-result" class="mt-6 hidden">
        <div class="border-[3px] border-black rounded-2xl overflow-hidden bg-white shadow-[4px_4px_0_#000]">
          <!-- Result header -->
          <div class="bg-[#1B1B3D] px-6 py-4">
            <p class="text-[#FFD600] text-xs font-black uppercase tracking-widest mb-1" style="font-family:'Inter',system-ui,sans-serif;">Your Cover Direction</p>
            <h3 id="cover-concept-title" class="text-white text-xl font-black leading-tight" style="font-family:'Inter',system-ui,sans-serif;"></h3>
          </div>

          <div class="p-6 sm:p-7 space-y-4">
            <!-- Visual direction -->
            <div class="bg-[#FFFBF2] border-2 border-black rounded-xl p-4">
              <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">Visual Direction</p>
              <p id="cover-visual-summary" class="font-bold text-[#1B1B3D] text-sm leading-relaxed" style="font-family:'Inter',system-ui,sans-serif;"></p>
            </div>

            <!-- Color + Typography -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="bg-[#FFF3CD] border-2 border-black rounded-xl p-4">
                <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">Color Direction</p>
                <p id="cover-color-direction" class="font-bold text-[#1B1B3D] text-sm leading-relaxed" style="font-family:'Inter',system-ui,sans-serif;"></p>
              </div>
              <div class="bg-[#F0EEFF] border-2 border-black rounded-xl p-4">
                <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">Typography</p>
                <p id="cover-typography" class="font-bold text-[#1B1B3D] text-sm leading-relaxed" style="font-family:'Inter',system-ui,sans-serif;"></p>
              </div>
            </div>

            <!-- Layout + Best for -->
            <div class="grid sm:grid-cols-2 gap-4">
              <div class="bg-[#E3F4FF] border-2 border-black rounded-xl p-4">
                <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">Layout</p>
                <p id="cover-layout" class="font-bold text-[#1B1B3D] text-sm leading-relaxed" style="font-family:'Inter',system-ui,sans-serif;"></p>
              </div>
              <div class="bg-[#E3F9ED] border-2 border-black rounded-xl p-4">
                <p class="text-xs font-black uppercase tracking-widest text-[#8888A4] mb-1.5" style="font-family:'Inter',system-ui,sans-serif;">Best For</p>
                <p id="cover-best-for" class="font-bold text-[#1B1B3D] text-sm leading-relaxed" style="font-family:'Inter',system-ui,sans-serif;"></p>
              </div>
            </div>

            <!-- AI Image Prompt -->
            <div class="bg-[#1B1B3D] border-2 border-black rounded-xl p-4">
              <div class="flex items-center justify-between mb-2">
                <p class="text-xs font-black uppercase tracking-widest text-[#FFD600]" style="font-family:'Inter',system-ui,sans-serif;">AI Image Prompt</p>
                <button
                  id="cover-copy-prompt-btn"
                  type="button"
                  class="inline-flex items-center gap-1.5 bg-[#FFD600] text-black font-black text-xs px-3 py-1.5 rounded-lg border-2 border-[#FFD600] shadow-[2px_2px_0_rgba(255,214,0,0.3)] hover:shadow-[1px_1px_0_rgba(255,214,0,0.3)] hover:translate-x-[1px] hover:translate-y-[1px] transition-all duration-150"
                  style="font-family:'Inter',system-ui,sans-serif;"
                >
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                  </svg>
                  <span id="cover-copy-prompt-text">Copy Prompt</span>
                </button>
              </div>
              <p id="cover-image-prompt" class="text-[#B8B8D4] text-sm leading-relaxed font-mono" style="font-size:0.8rem;"></p>
            </div>

            <!-- Action buttons -->
            <div class="flex flex-col sm:flex-row gap-3 pt-1">
              <button
                id="cover-copy-brief-btn"
                type="button"
                class="flex-1 inline-flex items-center justify-center gap-2 bg-[#1B1B3D] text-white font-black text-sm px-5 py-3.5 rounded-xl border-[3px] border-black shadow-[3px_3px_0_#000] hover:shadow-[1px_1px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-150"
                style="font-family:'Inter',system-ui,sans-serif;"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                </svg>
                <span id="cover-copy-brief-text">Copy Full Creative Brief</span>
              </button>
              <button
                id="cover-regen-btn"
                type="button"
                class="inline-flex items-center justify-center gap-2 bg-white text-[#1B1B3D] font-bold text-sm px-5 py-3.5 rounded-xl border-[3px] border-black shadow-[3px_3px_0_#000] hover:shadow-[1px_1px_0_#000] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-150"
                style="font-family:'Inter',system-ui,sans-serif;"
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Regenerate
              </button>
            </div>

            <p class="text-xs text-[#B0B0C8] text-center pt-1" style="font-family:'Inter',system-ui,sans-serif;">
              Paste the image prompt into Midjourney, DALL-E, or Canva AI to generate a cover visual.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
  </div>
</div>

<script>
(function () {

// INTEGRATION POINT: replace generateCoverDirection() body with
// fetch('/api/generate-cover', { topic, audience, vibe, visualStyle, colorMood })

type CoverInputs = { topic: string; audience: string; vibe: string; visualStyle: string; colorMood: string; variant: number; };

// ─── DATA ────────────────────────────────────────────────────────────────────

