const audienceLabels: Record<string, string> = {
  beginners:         "Complete beginners who are just getting started",
  busy_professionals:"Busy professionals who need fast, practical solutions",
  freelancers:       "Freelancers and self-employed people building on their own",
  creators:          "Content creators and digital entrepreneurs",
  parents:           "Parents balancing family life with personal goals",
  students:          "Students who want to get ahead faster",
  remote_workers:    "Remote workers and location-independent people",
};

// ─── STATE ──────────────────────────────────────────────────────────────────

let variantIndex = 0;
let lastInputHash = '';

// ─── HELPERS ────────────────────────────────────────────────────────────────

function capitalize(str: string): string {
  return str.charAt(0).toUpperCase() + str.slice(1);
}

function pick<T>(arr: T[], index: number): T {
  return arr[index % arr.length];
}

function interpolate(template: string, topic: string): string {
  return template.replace(/\{topic\}/g, topic);
}

// ─── GENERATION ─────────────────────────────────────────────────────────────

function generateIdea(topic: string, audience: string, outcome: string, productType: string, variant: number) {
  const t = topic.trim() || "your topic";

  const titleArr = titlePrefixes[productType]?.[audience] ?? [`The ${capitalize(t)} ${capitalize(productType)}`];
  const title = interpolate(pick(titleArr, variant), capitalize(t));

  const hookArr = hookTemplates[outcome]?.[productType] ?? ["A practical product built around what you already know."];
  const hook = interpolate(pick(hookArr, variant), t);

  const sectionsArr = sectionsByType[productType] ?? [["Introduction", "Core Content", "Action Steps", "Summary"]];
  const sections = pick(sectionsArr, variant);

  const priceArr = priceByType[productType] ?? ["$17 – $37"];
  const price = pick(priceArr, variant);

  const format = formatByType[productType] ?? "PDF";
  const audience_label = audienceLabels[audience] ?? audience;

  const problemArr = problemMap[outcome] ?? ["A common challenge people face with this topic"];
  const problem = pick(problemArr, variant);

  return { title, hook, sections, price, format, audience_label, problem };
}

// ─── DOM UPDATE ─────────────────────────────────────────────────────────────

function renderResult(data: ReturnType<typeof generateIdea>) {
  const resultCard = document.getElementById('result-card')!;
  const emptyState = document.getElementById('empty-state')!;

  (document.getElementById('result-title') as HTMLElement).textContent = data.title;
  (document.getElementById('result-hook') as HTMLElement).textContent = data.hook;
  (document.getElementById('result-audience') as HTMLElement).textContent = data.audience_label;
  (document.getElementById('result-problem') as HTMLElement).textContent = data.problem;

  const sectionsList = document.getElementById('result-sections')!;
  sectionsList.innerHTML = data.sections.map((s: string) => `
    <li class="flex items-start gap-2 text-sm font-medium text-[#1B1B3D]" style="font-family:'Inter',system-ui,sans-serif;">
      <span class="mt-0.5 w-5 h-5 rounded-full bg-[#FFD600] border-2 border-black flex items-center justify-center text-xs font-black shrink-0">✓</span>
      ${s}
    </li>
  `).join('');

  (document.getElementById('result-price') as HTMLElement).textContent = data.price;
  (document.getElementById('result-format') as HTMLElement).textContent = data.format;

  emptyState.classList.add('hidden');
  resultCard.classList.remove('hidden');
  resultCard.classList.add('result-reveal');
  setTimeout(() => resultCard.classList.remove('result-reveal'), 600);
}

// ─── INIT ────────────────────────────────────────────────────────────────────

document.addEventListener('DOMContentLoaded', () => {
  const topicInput = document.getElementById('topic-input') as HTMLInputElement;
  const audienceSelect = document.getElementById('audience-select') as HTMLSelectElement;
  const outcomeSelect = document.getElementById('outcome-select') as HTMLSelectElement;
  const typeSelect = document.getElementById('type-select') as HTMLSelectElement;
  const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
  const regenerateBtn = document.getElementById('regenerate-btn') as HTMLButtonElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const copyBtnText = document.getElementById('copy-btn-text') as HTMLElement;

  // Topic chips
  document.querySelectorAll('.topic-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      topicInput.value = (chip as HTMLElement).dataset.topic ?? '';
      topicInput.focus();
    });
  });

  // Generate
  function runGenerate() {
    const topic = topicInput.value;
    const audience = audienceSelect.value;
    const outcome = outcomeSelect.value;
    const productType = typeSelect.value;

    const inputHash = `${topic}|${audience}|${outcome}|${productType}`;
    if (inputHash !== lastInputHash) {
      variantIndex = 0;
      lastInputHash = inputHash;
    }

    const data = generateIdea(topic, audience, outcome, productType, variantIndex);
    renderResult(data);
  }

  generateBtn.addEventListener('click', () => {
    const btn = generateBtn;
    const icon = document.getElementById('generate-btn-icon') as HTMLElement;
    const text = document.getElementById('generate-btn-text') as HTMLElement;

    icon.textContent = '⏳';
    text.textContent = 'Generating…';
    btn.disabled = true;

    setTimeout(() => {
      runGenerate();
      icon.textContent = '✨';
      text.textContent = 'Generate My Idea';
      btn.disabled = false;
    }, 600);
  });

  // Regenerate: cycles through variants
  regenerateBtn.addEventListener('click', () => {
    variantIndex++;
    runGenerate();
  });

  // Copy
  copyBtn.addEventListener('click', () => {
    const title = (document.getElementById('result-title') as HTMLElement).textContent ?? '';
    const hook = (document.getElementById('result-hook') as HTMLElement).textContent ?? '';
    const audience = (document.getElementById('result-audience') as HTMLElement).textContent ?? '';
    const problem = (document.getElementById('result-problem') as HTMLElement).textContent ?? '';
    const sections = Array.from(document.querySelectorAll('#result-sections li'))
      .map(li => `- ${li.textContent?.trim()}`)
      .join('\n');
    const price = (document.getElementById('result-price') as HTMLElement).textContent ?? '';
    const format = (document.getElementById('result-format') as HTMLElement).textContent ?? '';

    const text = `PRODUCT IDEA\n\n${title}\n\nHook: ${hook}\n\nBest for: ${audience}\n\nProblem: ${problem}\n\nWhat to include:\n${sections}\n\nPrice range: ${price}\nFormat: ${format}\n\nGenerated by Strategic Sloth Idea Builder`;

    navigator.clipboard.writeText(text).then(() => {
      copyBtnText.textContent = 'Copied!';
      setTimeout(() => { copyBtnText.textContent = 'Copy Idea'; }, 2000);
    });
  });
});
</script>

