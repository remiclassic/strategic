  href: '/reading-guide#scale',
  variant: 'epic',
  epic: {
    badge: 'TIER 3 · SCALE TO FREEDOM',
    headline: 'THE FULL TOOLKIT',
    subline: '11 books · the complete sovereignty stack',
    fomoLines: [
      '🔥 Full system is the fast lane. See what you get →',
      '⚡ Others leveled up to all 11 books. Don’t get left behind →',
      '🚀 Complete tier moving. Lock the whole library →',
      '👀 You’re still on starter energy? Peek the full path →',
