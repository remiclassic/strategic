---
import type { Book, Bundle } from '../../data/catalog-data';
import { getPrimaryBundle } from '../../data/catalog-data';

interface Props {
  book: Book;
}

const { book } = Astro.props;
const primaryBundle: Bundle | undefined = getPrimaryBundle(book);
const blogHref = book.blogSlug ? `/blog/${book.blogSlug}` : null;
---

<div class="book-card">
  <div class="book-card__shine" aria-hidden="true"></div>
  <div class="book-card__cover">
    <img
      src={book.coverImage}
      alt=""
      width="640"
      height="480"
      loading="lazy"
      decoding="async"
      class="book-card__cover-img"
    />
  </div>
  <div class="book-card__top">
    <h3 class="book-card__title">{book.title}</h3>
    <p class="book-card__benefit">{book.benefit}</p>
    <p class="book-card__detail">{book.detail}</p>
    {book.whatsInside && book.whatsInside.length > 0 && (
      <div class="book-card__inside">
        <p class="book-card__inside-label">What's inside</p>
        <ul class="book-card__inside-list">
          {book.whatsInside.map((item) => (
            <li class="book-card__inside-item">{item}</li>
          ))}
        </ul>
      </div>
    )}
    {blogHref && (
      <a href={blogHref} class="book-card__blog">
        Free overview on the blog →
      </a>
    )}
  </div>

  <div class="book-card__bottom">
    <div class="book-card__pricing">
      <span class="book-price">${book.price}</span>
    </div>

    <a href={book.checkoutUrl} class="book-card__cta">Buy Now</a>

    {primaryBundle && (
      <a href="#bundles" class="book-card__upsell">
        Also in <strong>{primaryBundle.name}</strong> → Save more
      </a>
    )}
  </div>
</div>

<style>
  .book-card {
    position: relative;
    overflow: hidden;
    background: #fff;
    border: 2px solid #e4e4f0;
    border-radius: 12px;
    box-shadow: 3px 3px 0 rgba(0, 0, 0, 0.08);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 0;
    transition:
      transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.18s ease,
      border-color 0.18s ease;
    gap: 0;
  }

  .book-card__cover {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    background: linear-gradient(145deg, #f8f8fc 0%, #ececf5 100%);
    border-bottom: 2px solid #e4e4f0;
    flex-shrink: 0;
  }

  .book-card__cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .book-card__shine {
    position: absolute;
    top: -40%;
    left: -60%;
    width: 40%;
    height: 180%;
    background: linear-gradient(
      105deg,
      transparent 0%,
      rgba(255, 214, 0, 0.15) 45%,
      transparent 70%
    );
    transform: rotate(12deg);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .book-card:hover {
    transform: translateY(-4px) rotate(-0.5deg);
    box-shadow: 5px 6px 0 #1b1b3d;
    border-color: #1b1b3d;
  }

  .book-card:hover .book-card__shine {
    opacity: 1;
    animation: bookCardShine 1.2s ease-out forwards;
  }

  @keyframes bookCardShine {
    0% {
      left: -60%;
    }
    100% {
      left: 120%;
    }
  }

  .book-card__top {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem 1.25rem 0;
  }

  .book-card__title {
    font-family: 'Inter', sans-serif;
    font-size: 0.95rem;
    font-weight: 800;
    color: #1b1b3d;
    margin: 0;
    line-height: 1.35;
    transition: color 0.15s ease;
  }

  .book-card:hover .book-card__title {
    color: #2c2d5d;
  }

  .book-card__benefit {
    font-family: 'Inter', sans-serif;
    font-size: 0.82rem;
    color: #6666aa;
    margin: 0;
    line-height: 1.4;
  }

  .book-card__detail {
    font-family: 'Inter', sans-serif;
    font-size: 0.78rem;
    color: #555577;
    margin: 0;
    line-height: 1.45;
  }

  .book-card__inside {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid #e8e8f0;
  }

  .book-card__inside-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: #9999bb;
    margin: 0 0 0.35rem;
  }

  .book-card__inside-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .book-card__inside-item {
    font-family: 'Inter', sans-serif;
    font-size: 0.72rem;
    color: #44446a;
    line-height: 1.4;
    padding-left: 0.85rem;
    position: relative;
  }

  .book-card__inside-item::before {
    content: '→';
    position: absolute;
    left: 0;
    color: #9999bb;
    font-size: 0.65rem;
    top: 0.05em;
  }

  .book-card__blog {
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    font-weight: 600;
    color: #1B1B3D;
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-top: 0.15rem;
    align-self: flex-start;
    transition: color 0.15s ease;
  }

  .book-card__blog:hover {
    color: #4444aa;
  }

  .book-card__bottom {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding: 0 1.25rem 1.25rem;
    margin-top: 1rem;
  }

  .book-card__pricing {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .book-price {
    font-family: 'Bangers', cursive;
    font-size: 1.7rem;
    letter-spacing: 0.03em;
    color: #1B1B3D;
    line-height: 1;
  }

  .book-card__cta {
    display: block;
    text-align: center;
    background: #1B1B3D;
    color: #FFD600;
    font-family: 'Inter', sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 0.6rem 1rem;
    border-radius: 7px;
    border: 2px solid #000;
    box-shadow: 2px 2px 0 #000;
    text-decoration: none;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
    min-height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .book-card__cta:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 #000;
  }

  .book-card__cta:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 #000;
  }

  .book-card__upsell {
    font-family: 'Inter', sans-serif;
    font-size: 0.74rem;
    color: #8888bb;
    text-align: center;
    text-decoration: none;
    line-height: 1.4;
    padding: 0.2rem 0;
    transition: color 0.15s ease;
    display: block;
  }

  .book-card__upsell:hover {
    color: #1B1B3D;
    text-decoration: underline;
  }

  .book-card__upsell strong {
    font-weight: 600;
    color: #1b1b3d;
  }

  @media (prefers-reduced-motion: reduce) {
    .book-card,
    .book-card:hover {
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
      transform: none;
    }

    .book-card:hover .book-card__shine {
      animation: none;
      opacity: 0;
    }
  }
</style>
